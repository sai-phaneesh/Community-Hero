# === ENVIRONMENT ===
NODE_ENV=production
PORT=8080

# App URL (automatically set by Cloud Run, or set manually)
APP_URL="https://your-cloud-run-url.run.app"

# === DATABASE ===
# CockroachDB connection string
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=verify-full"

# Alternatively, if no DATABASE_URL, app falls back to local JSON database mode
# DATABASE_URL= (empty or not set)

# === API KEYS ===
# Gemini AI API Key (for AI features)
GEMINI_API_KEY="your-gemini-api-key-here"

# JWT Secret (for authentication tokens)
JWT_SECRET="your-super-secret-jwt-key-here"

# === CORS ===
# Allowed origins for API requests (comma-separated)
ALLOWED_ORIGINS="https://your-firebase-hosting-url.web.app,http://localhost:5173"

# === FRONTEND API URL ===
# Backend URL for frontend to call (used in VITE_API_URL)
# Leave empty for local development (uses relative /trpc path)
# Set for production or when frontend and backend are on different domains
VITE_API_URL="https://your-cloud-run-backend-url.run.app"

