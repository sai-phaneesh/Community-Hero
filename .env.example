# === DEPLOYMENT ===
NODE_ENV=production
PORT=8080

# App URL (automatically set by Cloud Run, or set manually)
APP_URL="https://your-cloud-run-url.run.app"

# === DATABASE ===
# For Cloud SQL PostgreSQL (Cloud Run)
# Format: postgresql://username:password@/database?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# Or for public IP: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# === API KEYS ===
# Gemini AI API Key (for AI features)
GEMINI_API_KEY="your-gemini-api-key-here"

# === FIREBASE (Optional - for additional features) ===
# These are usually configured in your frontend code via firebase config
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"

