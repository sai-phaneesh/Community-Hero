    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans\">\n      {/* Top Navigation */}\n      <header className=\"sticky top-0 z-40 bg-slate-900/90 border-b border-slate-800 backdrop-blur-md px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"h-10 w-10 bg-teal-500 rounded-xl flex items-center justify-center text-slate-950 font-bold shadow-lg shadow-teal-500/15\">\n            CH\n          </div>\n          <div>\n            <h1 className=\"text-lg font-bold tracking-tight text-white leading-tight\">Community Hero</h1>\n            <span className=\"text-xs text-slate-400 font-mono\">Hyperlocal Action Network</span>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          {/* Notifications Center */}\n          <div className=\"relative\">\n            <button\n              onClick={() => setShowNotifications(!showNotifications)}\n              className=\"p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg relative transition-all\"\n              title=\"Notifications\"\n            >\n              <Bell className=\"h-5 w-5\" />\n              {unreadNotifs > 0 && (\n                <span className=\"absolute -top-0.5 -right-0.5 bg-rose-500 text-white font-bold text-[10px] h-4 min-w-4 px-1 rounded-full flex items-center justify-center border-2 border-slate-900 animate-pulse\">\n                  {unreadNotifs}\n                </span>\n              )}\n            </button>\n\n            {showNotifications && (\n              <div className=\"absolute right-0 mt-2 w-80 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-4 max-h-96 overflow-y-auto z-50 animate-fadeIn\">\n                <div className=\"flex items-center justify-between border-b border-slate-800 pb-2 mb-2\">\n                  <h3 className=\"font-semibold text-sm text-white\">Notifications Feed</h3>\n                  <button\n                    onClick={() => setShowNotifications(false)}\n                    className=\"text-xs text-slate-400 hover:text-teal-400\"\n                  >\n                    Close\n                  </button>\n                </div>\n                {notifications.length === 0 ? (\n                  <p className=\"text-xs text-slate-500 text-center py-4\">No notifications yet.</p>\n                ) : (\n                  <div className=\"space-y-2\">\n                    {notifications.map((notif) => (\n                      <div\n                        key={notif.id}\n                        onClick={() => handleMarkNotifRead(notif.id)}\n                        className={`p-2.5 rounded-lg border text-left cursor-pointer transition-all ${\n                          notif.read\n                            ? \"bg-slate-950/40 border-slate-900/40 text-slate-400\"\n                            : \"bg-teal-950/20 border-teal-500/30 text-slate-200 hover:border-teal-500/50\"\n                        }`}\n                      >\n                        <p className=\"text-xs font-semibold flex items-center gap-1\">\n                          {!notif.read && <span className=\"h-1.5 w-1.5 bg-teal-400 rounded-full shrink-0\"></span>}\n                          {notif.title}\n                        </p>\n                        <p className=\"text-[11px] mt-1 leading-relaxed\">{notif.message}</p>\n                        <span className=\"text-[9px] text-slate-500 font-mono block mt-1.5\">\n                          {new Date(notif.createdAt).toLocaleTimeString()}\n                        </span>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* User Profile Info Tag */}\n          <div className=\"hidden md:flex flex-col items-end text-right\">\n            <span className=\"text-sm font-semibold text-white\">{user.name}</span>\n            <span className=\"text-xs text-teal-400 font-mono uppercase tracking-wider font-semibold\">\n              {user.role} {user.houseNumber ? `(House ${user.houseNumber})` : user.specialty ? `(${user.specialty})` : \"\"}\n            </span>\n          </div>\n\n          <button\n            onClick={onLogout}\n            className=\"p-2 text-slate-400 hover:text-rose-400 hover:bg-slate-800 rounded-lg transition-all\"\n            title=\"Log out\"\n          >\n            <LogOut className=\"h-5 w-5\" />\n          </button>\n        </div>\n      </header>\n\n      {/* Main Sub-Nav & Layout Container */}\n      <div className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row gap-6\">"
        replacement_content: "  return (\n    <div className=\"min-h-screen bg-slate-50 text-slate-900 flex flex-col font-sans\">\n      {/* Top Navigation */}\n      <header className=\"sticky top-0 z-40 h-14 bg-slate-900 text-white flex items-center justify-between px-4 sm:px-6 lg:px-8 shrink-0 shadow-lg\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-8 h-8 bg-emerald-500 rounded flex items-center justify-center font-bold text-lg text-slate-950\">\n            C\n          </div>\n          <div>\n            <h1 className=\"text-sm font-extrabold tracking-tight text-white uppercase flex items-center gap-1.5 leading-none\">\n              COMMUNITY<span className=\"text-emerald-400\">HERO</span>\n            </h1>\n            <span className=\"text-[9px] text-slate-400 font-mono tracking-widest uppercase\">Hyperlocal Action Terminal</span>\n          </div>\n          <span className=\"hidden md:inline-block ml-4 px-2 py-0.5 bg-slate-800 border border-slate-700 rounded text-[9px] text-slate-400 uppercase tracking-widest font-mono\">\n            Admin Terminal v2.4\n          </span>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          {/* Header Metrics */}\n          <div className=\"hidden lg:flex gap-4\">\n            <div className=\"text-right\">\n              <p className=\"text-[9px] text-slate-400 uppercase font-mono\">Civic Trust Score</p>\n              <p className=\"text-emerald-400 font-mono text-xs font-bold\">84.2%</p>\n            </div>\n            <div className=\"text-right border-l border-slate-700 pl-4\">\n              <p className=\"text-[9px] text-slate-400 uppercase font-mono\">Active Tickets</p>\n              <p className=\"text-emerald-400 font-mono text-xs font-bold\">\n                {issues.filter(i => i.status !== \"Resolved\").length}\n              </p>\n            </div>\n          </div>\n\n          {/* Notifications Center */}\n          <div className=\"relative border-l border-slate-700 pl-4\">\n            <button\n              onClick={() => setShowNotifications(!showNotifications)}\n              className=\"p-1.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded relative transition-all\"\n              title=\"Notifications\"\n            >\n              <Bell className=\"h-4 w-4\" />\n              {unreadNotifs > 0 && (\n                <span className=\"absolute -top-0.5 -right-0.5 bg-emerald-500 text-slate-950 font-extrabold text-[9px] h-3.5 min-w-3.5 px-0.5 rounded-full flex items-center justify-center border border-slate-900\">\n                  {unreadNotifs}\n                </span>\n              )}\n            </button>\n\n            {showNotifications && (\n              <div className=\"absolute right-0 mt-2 w-80 bg-white border border-slate-300 rounded shadow-xl p-4 max-h-96 overflow-y-auto z-50 text-slate-900\">\n                <div className=\"flex items-center justify-between border-b border-slate-200 pb-2 mb-2\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider\">Notifications Feed</h3>\n                  <button\n                    onClick={() => setShowNotifications(false)}\n                    className=\"text-[10px] font-mono text-slate-500 hover:text-emerald-600\"\n                  >\n                    Close\n                  </button>\n                </div>\n                {notifications.length === 0 ? (\n                  <p className=\"text-xs text-slate-400 text-center py-4 font-mono\">No notifications yet.</p>\n                ) : (\n                  <div className=\"space-y-1.5\">\n                    {notifications.map((notif) => (\n                      <div\n                        key={notif.id}\n                        onClick={() => handleMarkNotifRead(notif.id)}\n                        className={`p-2 rounded border text-left cursor-pointer transition-all ${\n                          notif.read\n                            ? \"bg-slate-50 border-slate-200 text-slate-500\"\n                            : \"bg-emerald-50/50 border-emerald-300 text-slate-800 hover:border-emerald-400\"\n                        }`}\n                      >\n                        <p className=\"text-xs font-semibold flex items-center gap-1\">\n                          {!notif.read && <span className=\"h-1.5 w-1.5 bg-emerald-500 rounded-full shrink-0\"></span>}\n                          {notif.title}\n                        </p>\n                        <p className=\"text-[11px] mt-1 leading-relaxed\">{notif.message}</p>\n                        <span className=\"text-[9px] text-slate-500 font-mono block mt-1.5\">\n                          {new Date(notif.createdAt).toLocaleTimeString()}\n                        </span>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* User Profile Info Tag */}\n          <div className=\"hidden sm:flex items-center gap-2 border-l border-slate-700 pl-4\">\n            <div className=\"w-7 h-7 rounded bg-slate-800 border border-slate-700 flex items-center justify-center text-[10px] font-bold text-emerald-400 font-mono\">\n              {user.name.slice(0, 2).toUpperCase()}\n            </div>\n            <div className=\"text-[11px] text-left\">\n              <p className=\"font-semibold text-slate-200\">{user.name}</p>\n              <p className=\"text-[9px] text-slate-400 uppercase font-mono tracking-wider\">\n                {user.role} {user.houseNumber ? `#${user.houseNumber}` : user.specialty ? `(${user.specialty})` : \"\"}\n              </p>\n            </div>\n          </div>\n\n          <button\n            onClick={onLogout}\n            className=\"p-1.5 text-slate-400 hover:text-rose-400 hover:bg-slate-800 rounded transition-all pl-4\"\n            title=\"Log out\"\n          >\n            <LogOut className=\"h-4 w-4\" />\n          </button>\n        </div>\n      </header>\n\n      {/* Main Sub-Nav & Layout Container */}\n      <div className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row gap-4\">"
