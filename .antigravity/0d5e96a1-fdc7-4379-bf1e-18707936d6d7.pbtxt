        lines {
          text: "  AlertTriangle,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Clock,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  ThumbsUp,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  UserCheck,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  CheckCircle,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  PlusCircle,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  TrendingUp,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Award,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  DollarSign,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  MapPin,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  ClipboardList,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Sparkles,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Search,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  CheckCircle2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Calendar,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Send,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  MessageSquare,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Bell,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  LogOut,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Sliders,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  AlertCircle,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  Home,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  FileText"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "} from \"lucide-react\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
