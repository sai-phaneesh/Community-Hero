          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          <div className=\"bg-slate-50 p-1.5 rounded flex justify-between items-center border border-slate-200\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                            <span className=\"text-slate-500 text-[10px]\">Cleanliness:</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
