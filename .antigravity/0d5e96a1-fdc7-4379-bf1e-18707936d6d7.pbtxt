> setHouseNumber(e.target.value)}\n                    placeholder=\"e.g. A-12 or Apt 4B\"\n                    className=\"w-full bg-slate-900 border border-slate-700 rounded-lg py-2.5 px-3.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\"\n                  />\n                  <p className=\"mt-1 text-xs text-slate-500\">\n                    Required for tracking deliveries and service requests accurately.\n                  </p>\n                </div>\n              )}\n\n              {/* Specialty (Contractor only) */}\n              {role === \"contractor\" && (\n                <div className=\"animate-fadeIn\">\n                  <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1\">\n                    Service Specialty / Trade\n                  </label>\n                  <select\n                    value={specialty}\n                    onChange={(e) => setSpecialty(e.target.value)}\n                    className=\"w-full bg-slate-900 border border-slate-700 rounded-lg py-2.5 px-3.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\"\n                  >\n                    <option value=\"Plumber\">Plumber (Water leaks, piping)</option>\n                    <option value=\"Electrician\">Electrician (Streetlights, power issues)</option>\n                    <option value=\"Waste Management\">Waste & Garbage Contractor</option>\n                    <option value=\"Gardening\">Community Landscaper / Gardener</option>\n                    <option value=\"Roads\">Civil / Roadwork Repairs</option>\n                  </select>\n                </div>\n              )}\n            </>\n          )}\n\n          {/* Email */}\n          <div>\n            <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1\">\n              Email Address\n            </label>\n            <input\n              type=\"email\"\