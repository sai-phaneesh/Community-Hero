        }
        lines {
          text: "                          <div className=\"bg-slate-50 p-2.5 rounded border border-slate-200 mt-2.5 text-xs leading-normal\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                            <strong className=\"text-slate-500 block mb-0.5 text-[10px] uppercase tracking-wider\">Suggestions & Observations:</strong>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                            <p className=\"text-slate-700\">\342\200\234{survey.feedbackText}\342\200\235</p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
