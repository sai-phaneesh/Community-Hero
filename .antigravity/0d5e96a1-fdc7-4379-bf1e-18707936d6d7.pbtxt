  file_change {
    absolute_path_uri: "file:///src/components/Dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \"react\";\nimport { User, Issue, Survey, Notification } from \"../types\";\nimport {\n  AlertTriangle,\n  Clock,\n  ThumbsUp,\n  UserCheck,\n  CheckCircle,\n  PlusCircle,\n  TrendingUp,\n  Award,\n  DollarSign,\n  MapPin,\n  ClipboardList,\n  Sparkles,\n  Search,\n  CheckCircle2,\n  Calendar,\n  Send,\n  MessageSquare,\n  Bell,\n  LogOut,\n  Sliders,\n  AlertCircle,\n  Home,\n  FileText\n} from \"lucide-react\";\nimport {\n  BarChart,\n  Bar,\n  XAxis,\n  YAxis,\n  CartesianGrid,\n  Tooltip,\n  ResponsiveContainer,\n  Legend,\n  PieChart,\n  Pie,\n  Cell\n} from \"recharts\";\n\ninterface DashboardProps {\n  user: User;\n  onLogout: () => void;\n}\n\nexport default function Dashboard({ user, onLogout }: DashboardProps) {\n  // Common states\n  const [issues, setIssues] = useState<Issue[]>([]);\n  const [notifications, setNotifications] = useState<Notification[]>([]);\n  const [activeTab, setActiveTab] = useState<\"issues\" | \"report\" | \"survey\" | \"contractor\" | \"admin-dashboard\" | \"admin-surveys\">(\"issues\");\n  \n  // Reporting states\n  const [reportTitle, setReportTitle] = useState(\"\");\n  const [reportDesc, setReportDesc] = useState(\"\");\n  const [aiLoading, setAiLoading] = useState(false);\n  const [aiAnalysis, setAiAnalysis] = useState<{\n    category: string;\n    severity: string;\n    wasteCaused: string;\n    repairSuggestion: string;\n    authenticityClues: string;\n  } | null>(null);\n  \n  // Custom manual overrides for reporting\n  const [manualCategory, setManualCategory] = useState(\"Water Leakage\");\n  const [manualSeverity, setManualSeverity] = useState<\"Low\" | \"Medium\" | \"High\" | \"Critical\">(\"Medium\");\n  const [manualWaste, setManualWaste] = useState(\"\");\n  \n  // Survey states\n  const [surveyHappiness, setSurveyHappiness] = useState<number>(4);\n  const [surveyServices, setSurveyServices] = useState<number>(3);\n  const [surveyRoads, setSurveyRoads] = useState<number>(3);\n  const [surveyCleanliness, setSurveyCleanliness] = useState<number>(3);\n  const [surveyFeedback, setSurveyFeedback] = useState(\"\");\n  const [surveySuccess, setSurveySuccess] = useState(false);\n  const [surveyError, setSurveyError] = useState(\"\");\n\n  // Admin survey tracking states\n  const [adminSurveys, setAdminSurveys] = useState<Survey[]>([]);\n\n  // Contractor states\n  const [priceQuoteInput, setPriceQuoteInput] = useState<string>(\"150\");\n  const [resolutionNotesInput, setResolutionNotesInput] = useState(\"\");\n  const [selectedIssueForAction, setSelectedIssueForAction] = useState<string | null>(null);\n\n  // Filters & search\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [filterCategory, setFilterCategory] = useState(\"All\");\n  const [filterStatus, setFilterStatus] = useState(\"All\");\n\n  // Notifications\n  const [showNotifications, setShowNotifications] = useState(false);\n\n  // Fetch initial data\n  const fetchData = async () => {\n    try {\n      const issuesRes = await fetch(\"/api/issues\");\n      const issuesData = await issuesRes.json();\n      if (Array.isArray(issuesData)) {\n        setIssues(issuesData);\n      }\n\n      const notifRes = await fetch(`/api/notifications/${user.id}`);\n      const notifData = await notifRes.json();\n      if (Array.isArray(notifData)) {\n        setNotifications(notifData);\n      }\n\n      if (user.role === \"admin\") {\n        const surveyRes = await fetch(\"/api/surveys\");\n        const surveyData = await surveyRes.json();\n        if (Array.isArray(surveyData)) {\n          setAdminSurveys(surveyData);\n        }\n      }\n    } catch (err) {\n      console.error(\"Error fetching dashboard data\", err);\n    }\n  };\n\n  useEffect(() => {\n    fetchData();\n    // Auto-refresh every 10 seconds for simulated real-time tracking\n    const interval = setInterval(fetchData, 10000);\n    return () => clearInterval(interval);\n  }, [user.id]);\n\n  // Handle Tab changes automatically based on role initial states\n  useEffect(() => {\n    if (user.role === \"admin\") {\n      setActiveTab(\"admin-dashboard\");\n    } else if (user.role === \"contractor\") {\n      setActiveTab(\"contractor\");\n    } else {\n      setActiveTab(\"issues\");\n    }\n  }, [user.role]);\n\n  // Mark notification read\n  const handleMarkNotifRead = async (id: string) => {\n    try {\n      await fetch(`/api/notifications/${id}/read`, { method: \"POST\" });\n      setNotifications(prev =>\n        prev.map(n => (n.id === id ? { ...n, read: true } : n))\n      );\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Run AI analysis with Gemini\n  const handleAiAnalyze = async () => {\n    if (!reportTitle || !reportDesc) {\n      alert(\"Please provide a title and description first to enable AI analysis.\");\n      return;\n    }\n    setAiLoading(true);\n    setAiAnalysis(null);\n    try {\n      const res = await fetch(\"/api/issues/analyze\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ title: reportTitle, description: reportDesc }),\n      });\n      const data = await res.json();\n      if (res.ok) {\n        setAiAnalysis(data);\n        setManualCategory(data.category);\n        setManualSeverity(data.severity);\n        setManualWaste(data.wasteCaused);\n      } else {\n        alert(data.error || \"AI analysis failed.\");\n      }\n    } catch (err) {\n      console.error(err);\n    } finally {\n      setAiLoading(false);\n    }\n  };\n\n  // Submit new issue\n  const handleReportSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!reportTitle || !reportDesc) return;\n\n    const payload = {\n      title: reportTitle,\n      description: reportDesc,\n      category: manualCategory,\n      severity: manualSeverity,\n      wasteCaused: manualWaste || \"Resource leakage under evaluation.\",\n      reporterId: user.id,\n      reporterName: user.name,\n      reporterHouse: user.houseNumber || \"N/A\",\n    };\n\n    try {\n      const res = await fetch(\"/api/issues/report\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload),\n      });\n      if (res.ok) {\n        setReportTitle(\"\");\n        setReportDesc(\"\");\n        setAiAnalysis(null);\n        setActiveTab(\"issues\");\n        fetchData();\n      } else {\n        const d = await res.json();\n        alert(d.error || \"Error reporting issue\");\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Community validation upvote\n  const handleVote = async (id: string) => {\n    try {\n      const res = await fetch(`/api/issues/${id}/validate`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ userId: user.id }),\n      });\n      if (res.ok) {\n        fetchData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Submit survey\n  const handleSurveySubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setSurveyError(\"\");\n    setSurveySuccess(false);\n\n    try {\n      const res = await fetch(\"/api/surveys\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          residentId: user.id,\n          residentName: user.name,\n          overallHappiness: surveyHappiness,\n          localServicesRating: surveyServices,\n          roadQualityRating: surveyRoads,\n          cleanlinessRating: surveyCleanliness,\n          feedbackText: surveyFeedback,\n        }),\n      });\n\n      const data = await res.json();\n      if (res.ok) {\n        setSurveySuccess(true);\n        setSurveyFeedback(\"\");\n      } else {\n        setSurveyError(data.error || \"Failed to submit survey\");\n      }\n    } catch (err) {\n      setSurveyError(\"Server connection lost.\");\n    }\n  };\n\n  // Contractor: Accept assignment\n  const handleAcceptAssignment = async (issueId: string) => {\n    const q = Number(priceQuoteInput) || 150;\n    try {\n      const res = await fetch(`/api/issues/${issueId}/assign`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ contractorId: user.id, priceQuote: q }),\n      });\n      if (res.ok) {\n        setSelectedIssueForAction(null);\n        fetchData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Contractor: Start progress\n  const handleStartProgress = async (issueId: string) => {\n    try {\n      const res = await fetch(`/api/issues/${issueId}/start`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ contractorId: user.id }),\n      });\n      if (res.ok) {\n        fetchData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Contractor: Resolve issue\n  const handleResolveIssue = async (issueId: string) => {\n    try {\n      const res = await fetch(`/api/issues/${issueId}/resolve`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          contractorId: user.id,\n          resolutionNotes: resolutionNotesInput || \"Completed repair successfully.\",\n        }),\n      });\n      if (res.ok) {\n        setSelectedIssueForAction(null);\n        setResolutionNotesInput(\"\");\n        fetchData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Admin: Approve/Release Payment\n  const handleReleasePayment = async (issueId: string) => {\n    try {\n      const res = await fetch(`/api/issues/${issueId}/pay`, { method: \"POST\" });\n      if (res.ok) {\n        fetchData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // --- FILTERS & SEARCH PROCESS ---\n  const filteredIssues = issues.filter(iss => {\n    const matchesSearch =\n      iss.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      iss.description.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      iss.reporterName.toLowerCase().includes(searchQuery.toLowerCase());\n    \n    const matchesCategory = filterCategory === \"All\" || iss.category === filterCategory;\n    const matchesStatus = filterStatus === \"All\" || iss.status === filterStatus;\n\n    return matchesSearch && matchesCategory && matchesStatus;\n  });\n\n  const unreadNotifs = notifications.filter(n => !n.read).length;\n\n  // --- CHART DATA PREPARATION (Admin only) ---\n  const getCategoryChartData = () => {\n    const counts: { [key: string]: number } = {};\n    issues.forEach(i => {\n      counts[i.category] = (counts[i.category] || 0) + 1;\n    });\n    return Object.keys(counts).map(cat => ({\n      name: cat,\n      value: counts[cat],\n    }));\n  };\n\n  const getStatusChartData = () => {\n    const counts = { Reported: 0, Validated: 0, Assigned: 0, \"In Progress\": 0, Resolved: 0 };\n    issues.forEach(i => {\n      if (i.status in counts) {\n        counts[i.status as keyof typeof counts]++;\n      }\n    });\n    return Object.keys(counts).map(st => ({\n      name: st,\n      count: counts[st as keyof typeof counts],\n    }));\n  };\n\n  const getSurveyWellbeingData = () => {\n    if (adminSurveys.length === 0) return [];\n    \n    // Group ratings by month\n    const monthsGroup: { [key: string]: { happiness: number[]; services: number[]; roads: number[]; cleanliness: number[] } } = {};\n    adminSurveys.forEach(s => {\n      if (!monthsGroup[s.month]) {\n        monthsGroup[s.month] = { happiness: [], services: [], roads: [], cleanliness: [] };\n      }\n      monthsGroup[s.month].happiness.push(s.overallHappiness);\n      monthsGroup[s.month].services.push(s.localServicesRating);\n      monthsGroup[s.month].roads.push(s.roadQualityRating);\n      monthsGroup[s.month].cleanliness.push(s.cleanlinessRating);\n    });\n\n    const avg = (arr: number[]) => arr.reduce((a, b) => a + b, 0) / arr.length;\n\n    return Object.keys(monthsGroup).map(month => ({\n      month,\n      \"Happiness\": Number(avg(monthsGroup[month].happiness).toFixed(1)),\n      \"Service Delivery\": Number(avg(monthsGroup[month].services).toFixed(1)),\n      \"Road Safety\": Number(avg(monthsGroup[month].roads).toFixed(1)),\n      \"Sanitation\": Number(avg(monthsGroup[month].cleanliness).toFixed(1)),\n    }));\n  };\n\n  const COLORS = [\"#14b8a6\", \"#3b82f6\", \"#f59e0b\", \"#ef4444\", \"#10b981\", \"#8b5cf6\"];\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans\">\n      {/* Top Navigation */}\n      <header className=\"sticky top-0 z-40 bg-slate-900/90 border-b border-slate-800 backdrop-blur-md px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"h-10 w-10 bg-teal-500 rounded-xl flex items-center justify-center text-slate-950 font-bold shadow-lg shadow-teal-500/15\">\n            CH\n          </div>\n          <div>\n            <h1 className=\"text-lg font-bold tracking-tight text-white leading-tight\">Community Hero</h1>\n            <span className=\"text-xs text-slate-400 font-mono\">Hyperlocal Action Network</span>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          {/* Notifications Center */}\n          <div className=\"relative\">\n            <button\n              onClick={() => setShowNotifications(!showNotifications)}\n              className=\"p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg relative transition-all\"\n              title=\"Notifications\"\n            >\n              <Bell className=\"h-5 w-5\" />\n              {unreadNotifs > 0 && (\n                <span className=\"absolute -top-0.5 -right-0.5 bg-rose-500 text-white font-bold text-[10px] h-4 min-w-4 px-1 rounded-full flex items-center justify-center border-2 border-slate-900 animate-pulse\">\n                  {unreadNotifs}\n                </span>\n              )}\n            </button>\n\n            {showNotifications && (\n              <div className=\"absolute right-0 mt-2 w-80 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-4 max-h-96 overflow-y-auto z-50 animate-fadeIn\">\n                <div className=\"flex items-center justify-between border-b border-slate-800 pb-2 mb-2\">\n                  <h3 className=\"font-semibold text-sm text-white\">Notifications Feed</h3>\n                  <button\n                    onClick={() => setShowNotifications(false)}\n                    className=\"text-xs text-slate-400 hover:text-teal-400\"\n                  >\n                    Close\n                  </button>\n                </div>\n                {notifications.length === 0 ? (\n                  <p className=\"text-xs text-slate-500 text-center py-4\">No notifications yet.</p>\n                ) : (\n                  <div className=\"space-y-2\">\n                    {notifications.map((notif) => (\n                      <div\n                        key={notif.id}\n                        onClick={() => handleMarkNotifRead(notif.id)}\n                        className={`p-2.5 rounded-lg border text-left cursor-pointer transition-all ${\n                          notif.read\n                            ? \"bg-slate-950/40 border-slate-900/40 text-slate-400\"\n                            : \"bg-teal-950/20 border-teal-500/30 text-slate-200 hover:border-teal-500/50\"\n                        }`}\n                      >\n                        <p className=\"text-xs font-semibold flex items-center gap-1\">\n                          {!notif.read && <span className=\"h-1.5 w-1.5 bg-teal-400 rounded-full shrink-0\"></span>}\n                          {notif.title}\n                        </p>\n                        <p className=\"text-[11px] mt-1 leading-relaxed\">{notif.message}</p>\n                        <span className=\"text-[9px] text-slate-500 font-mono block mt-1.5\">\n                          {new Date(notif.createdAt).toLocaleTimeString()}\n                        </span>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* User Profile Info Tag */}\n          <div className=\"hidden md:flex flex-col items-end text-right\">\n            <span className=\"text-sm font-semibold text-white\">{user.name}</span>\n            <span className=\"text-xs text-teal-400 font-mono uppercase tracking-wider font-semibold\">\n              {user.role} {user.houseNumber ? `(House ${user.houseNumber})` : user.specialty ? `(${user.specialty})` : \"\"}\n            </span>\n          </div>\n\n          <button\n            onClick={onLogout}\n            className=\"p-2 text-slate-400 hover:text-rose-400 hover:bg-slate-800 rounded-lg transition-all\"\n            title=\"Log out\"\n          >\n            <LogOut className=\"h-5 w-5\" />\n          </button>\n        </div>\n      </header>\n\n      {/* Main Sub-Nav & Layout Container */}\n      <div className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row gap-6\">\n        {/* Responsive Sidebar for Tab Selector */}\n        <aside className=\"w-full md:w-64 shrink-0 flex flex-col gap-2\">\n          <p className=\"text-[11px] font-semibold tracking-wider text-slate-500 uppercase px-3 mb-1\">Navigation Menu</p>\n          \n          {/* Universal tabs */}\n          <button\n            onClick={() => setActiveTab(\"issues\")}\n            className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n              activeTab === \"issues\"\n                ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n            }`}\n          >\n            <ClipboardList className=\"h-4.5 w-4.5\" />\n            Issues Hub\n          </button>\n\n          {/* Resident Specific Tabs */}\n          {user.role === \"resident\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"report\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"report\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <PlusCircle className=\"h-4.5 w-4.5\" />\n                Report New Issue\n              </button>\n              <button\n                onClick={() => setActiveTab(\"survey\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"survey\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <FileText className=\"h-4.5 w-4.5\" />\n                Monthly Well-being Survey\n              </button>\n            </>\n          )}\n\n          {/* Contractor Specific Tab */}\n          {user.role === \"contractor\" && (\n            <button\n              onClick={() => setActiveTab(\"contractor\")}\n              className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                activeTab === \"contractor\"\n                  ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                  : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n              }`}\n            >\n              <Sliders className=\"h-4.5 w-4.5\" />\n              Contractor Workroom\n            </button>\n          )}\n\n          {/* Admin Specific Tabs */}\n          {user.role === \"admin\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"admin-dashboard\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"admin-dashboard\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <TrendingUp className=\"h-4.5 w-4.5\" />\n                Governance & Analytics\n              </button>\n              <button\n                onClick={() => setActiveTab(\"admin-surveys\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"admin-surveys\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <MessageSquare className=\"h-4.5 w-4.5\" />\n                Resident Well-being Inbox\n              </button>\n            </>\n          )}\n\n          {/* Hero Stats Card Widget */}\n          <div className=\"mt-6 bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left hidden md:block\">\n            <h4 className=\"text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3\">Community Statistics</h4>\n            <div className=\"space-y-2\">\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Unresolved Issues</span>\n                <span className=\"font-semibold text-amber-400 font-mono\">\n                  {issues.filter(i => i.status !== \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Resolved to Date</span>\n                <span className=\"font-semibold text-emerald-400 font-mono\">\n                  {issues.filter(i => i.status === \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Active Handymen</span>\n                <span className=\"font-semibold text-teal-400 font-mono\">5 Registered</span>\n              </div>\n            </div>\n          </div>\n        </aside>\n\n        {/* Content Panel Area */}\n        <main className=\"flex-1 min-w-0\">\n          {/* TAB 1: ISSUES HUB */}\n          {activeTab === \"issues\" && (\n            <div className=\"space-y-6\">\n              {/* Header section with search */}\n              <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center\">\n                <div>\n                  <h2 className=\"text-2xl font-bold tracking-tight text-white font-sans\">Active Hyperlocal Reports</h2>\n                  <p className=\"text-slate-400 text-sm\">Review, validate, and follow resolving progress of neighborhood requests.</p>\n                </div>\n                {user.role === \"resident\" && (\n                  <button\n                    onClick={() => setActiveTab(\"report\")}\n                    className=\"flex items-center gap-1.5 bg-teal-500 text-slate-950 font-semibold px-4 py-2 rounded-lg text-sm hover:brightness-115 active:scale-95 transition-all\"\n                  >\n                    <PlusCircle className=\"h-4 w-4\" />\n                    Report Issue\n                  </button>\n                )}\n              </div>\n\n              {/* Filtering Interface */}\n              <div className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col md:flex-row gap-4 items-center\">\n                <div className=\"relative w-full md:flex-1\">\n                  <Search className=\"absolute left-3 top-3 h-4 w-4 text-slate-500\" />\n                  <input\n                    type=\"text\"\n                    value={searchQuery}\n                    onChange={(e) => setSearchQuery(e.target.value)}\n                    placeholder=\"Search issues, descriptions, houses...\"\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-xl pl-9 pr-4 py-2.5 text-slate-200 placeholder-slate-500 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                  />\n                </div>\n                <div className=\"flex gap-2 w-full md:w-auto\">\n                  <div className=\"flex-1 md:flex-none\">\n                    <select\n                      value={filterCategory}\n                      onChange={(e) => setFilterCategory(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl px-3 py-2.5 text-slate-300 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    >\n                      <option value=\"All\">All Categories</option>\n                      <option value=\"Water Leakage\">Water Leakage</option>\n                      <option value=\"Pothole\">Pothole</option>\n                      <option value=\"Waste Management\">Waste Management</option>\n                      <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                      <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                    </select>\n                  </div>\n                  <div className=\"flex-1 md:flex-none\">\n                    <select\n                      value={filterStatus}\n                      onChange={(e) => setFilterStatus(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl px-3 py-2.5 text-slate-300 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    >\n                      <option value=\"All\">All Statuses</option>\n                      <option value=\"Reported\">Reported</option>\n                      <option value=\"Validated\">Validated</option>\n                      <option value=\"Assigned\">Assigned</option>\n                      <option value=\"In Progress\">In Progress</option>\n                      <option value=\"Resolved\">Resolved</option>\n                    </select>\n                  </div>\n                </div>\n              </div>\n\n              {/* Grid representation */}\n              {filteredIssues.length === 0 ? (\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center\">\n                  <AlertTriangle className=\"h-10 w-10 text-slate-600 mx-auto mb-3\" />\n                  <h3 className=\"font-bold text-lg text-white\">No Issues Found</h3>\n                  <p className=\"text-slate-400 text-sm max-w-sm mx-auto mt-1\">There are no reports matching your search or filter configuration. Check back later!</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                  {filteredIssues.map((issue) => {\n                    const statusColors = {\n                      Reported: \"bg-amber-500/10 border-amber-500/30 text-amber-400\",\n                      Validated: \"bg-blue-500/10 border-blue-500/30 text-blue-400\",\n                      Assigned: \"bg-purple-500/10 border-purple-500/30 text-purple-400\",\n                      \"In Progress\": \"bg-sky-500/10 border-sky-500/30 text-sky-400\",\n                      Resolved: \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\",\n                    };\n\n                    const isUpvoted = issue.upvotes.includes(user.id);\n\n                    return (\n                      <div\n                        key={issue.id}\n                        className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 hover:border-slate-700/80 transition-all flex flex-col justify-between\"\n                      >\n                        <div>\n                          {/* Top tags */}\n                          <div className=\"flex justify-between items-start gap-2 mb-3\">\n                            <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">\n                              ID: {issue.id}\n                            </span>\n                            <span className={`px-2 py-0.5 rounded-full text-xs font-semibold border ${statusColors[issue.status]}`}>\n                              {issue.status}\n                            </span>\n                          </div>\n\n                          {/* Title */}\n                          <h3 className=\"font-bold text-lg text-white group-hover:text-teal-400 leading-snug\">\n                            {issue.title}\n                          </h3>\n\n                          {/* Sub info */}\n                          <div className=\"flex items-center gap-2 mt-1.5 text-xs text-slate-400\">\n                            <MapPin className=\"h-3 w-3 shrink-0\" />\n                            <span>House {issue.reporterHouse}</span>\n                            <span>\342\200\242</span>\n                            <span>Reporter: {issue.reporterName}</span>\n                          </div>\n\n                          {/* Description */}\n                          <p className=\"text-slate-300 text-sm mt-3 leading-relaxed\">\n                            {issue.description}\n                          </p>\n\n                          {/* Impact Metrics box */}\n                          <div className=\"mt-4 bg-slate-950/80 border border-slate-800 rounded-xl p-3 space-y-2\">\n                            <div className=\"flex justify-between items-center text-xs\">\n                              <span className=\"text-slate-500 flex items-center gap-1\">\n                                <AlertTriangle className=\"h-3.5 w-3.5 text-rose-400 shrink-0\" />\n                                Category / Severity:\n                              </span>\n                              <span className=\"font-semibold text-slate-300\">\n                                {issue.category} \342\200\242{\" \"}\n                                <span className={\n                                  issue.severity === \"Critical\" || issue.severity === \"High\"\n                                    ? \"text-rose-400 font-bold\"\n                                    : \"text-slate-300\"\n                                }>\n                                  {issue.severity}\n                                </span>\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4 text-xs\">\n                              <span className=\"text-slate-500 shrink-0 flex items-center gap-1\">\n                                <Clock className=\"h-3.5 w-3.5 text-teal-400 shrink-0\" />\n                                Days Unattended:\n                              </span>\n                              <span className=\"font-mono text-slate-300 text-right\">\n                                {issue.status === \"Resolved\" ? \"Resolved\" : `${issue.daysUnattended} days unaddressed`}\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4 text-xs pt-1 border-t border-slate-800/40\">\n                              <span className=\"text-slate-500 shrink-0\">Wasted Resources:</span>\n                              <span className=\"font-semibold text-teal-400 text-right text-[11px]\">\n                                {issue.wasteCaused}\n                              </span>\n                            </div>\n\n                            {issue.assignedContractorName && (\n                              <div className=\"flex justify-between items-center text-xs pt-1 border-t border-slate-800/40\">\n                                <span className=\"text-slate-500 flex items-center gap-1\">\n                                  <UserCheck className=\"h-3.5 w-3.5 text-teal-400 shrink-0\" />\n                                  Assigned Service:\n                                </span>\n                                <span className=\"font-semibold text-teal-300\">\n                                  {issue.assignedContractorName} {issue.priceQuote ? `($${issue.priceQuote})` : \"\"}\n                                </span>\n                              </div>\n                            )}\n\n                            {issue.resolutionNotes && (\n                              <div className=\"bg-emerald-950/20 border border-emerald-500/20 rounded-lg p-2 mt-2 text-xs\">\n                                <span className=\"font-bold text-emerald-400\">Resolution Notes:</span>\n                                <p className=\"text-slate-300 mt-0.5\">{issue.resolutionNotes}</p>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n\n                        {/* Actions line */}\n                        <div className=\"mt-5 pt-4 border-t border-slate-800/60 flex items-center justify-between\">\n                          <button\n                            onClick={() => handleVote(issue.id)}\n                            className={`flex items-center gap-2 px-3.5 py-1.5 rounded-lg text-xs font-semibold border transition-all ${\n                              isUpvoted\n                                ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                                : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white hover:border-slate-700\"\n                            }`}\n                          >\n                            <ThumbsUp className=\"h-3.5 w-3.5\" />\n                            <span>\n                              {isUpvoted ? \"Validated\" : \"Validate / Upvote\"} ({issue.upvotes.length})\n                            </span>\n                          </button>\n\n                          <div className=\"text-[11px] text-slate-500 font-mono\">\n                            {new Date(issue.createdAt).toLocaleDateString()}\n                          </div>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n              )}\n            </div>\n          )}\n\n          {/* TAB 2: REPORT NEW ISSUE (Resident only) */}\n          {activeTab === \"report\" && (\n            <div className=\"space-y-6 max-w-2xl mx-auto\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Report a Hyperlocal Issue</h2>\n                <p className=\"text-slate-400 text-sm\">Provide details. Use our built-in Gemini AI audit tool to instantly categorize the issue and evaluate environmental waste impacts.</p>\n              </div>\n\n              <form onSubmit={handleReportSubmit} className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl space-y-5\">\n                {/* Title */}\n                <div>\n                  <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                    Issue Title / Summary\n                  </label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={reportTitle}\n                    onChange={(e) => setReportTitle(e.target.value)}\n                    placeholder=\"e.g. Broken water pipe leaking near central curb\"\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                  />\n                </div>\n\n                {/* Description */}\n                <div>\n                  <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                    Detailed Description\n                  </label>\n                  <textarea\n                    required\n                    rows={4}\n                    value={reportDesc}\n                    onChange={(e) => setReportDesc(e.target.value)}\n                    placeholder=\"Please specify exactly where the issue is, how long it\'s been active, and what kind of waste or risk it is generating...\"\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                  />\n                </div>\n\n                {/* AI Audit Activation Button */}\n                <div className=\"p-4 bg-teal-950/20 border border-teal-500/20 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3\">\n                  <div className=\"flex items-center gap-2\">\n                    <Sparkles className=\"h-5 w-5 text-teal-400 shrink-0 animate-bounce\" />\n                    <div>\n                      <p className=\"text-xs font-bold text-teal-300\">Gemini AI Category & Waste Auditor</p>\n                      <p className=\"text-[11px] text-slate-400 leading-relaxed\">Let AI automatically determine the category, severity level, and waste footprint.</p>\n                    </div>\n                  </div>\n                  <button\n                    type=\"button\"\n                    onClick={handleAiAnalyze}\n                    disabled={aiLoading}\n                    className=\"shrink-0 flex items-center gap-1 bg-teal-500 text-slate-950 font-bold px-3 py-1.5 rounded-lg text-xs hover:bg-teal-400 transition-all disabled:opacity-50\"\n                  >\n                    {aiLoading ? \"Auditing...\" : \"Run AI Audit\"}\n                  </button>\n                </div>\n\n                {/* AI Analysis Result Showcase */}\n                {aiAnalysis && (\n                  <div className=\"bg-slate-950 border border-teal-500/20 rounded-xl p-4 space-y-3 text-sm animate-fadeIn\">\n                    <p className=\"text-xs font-bold text-teal-400 uppercase tracking-widest flex items-center gap-1\">\n                      <CheckCircle2 className=\"h-4 w-4\" /> AI Evaluation Completed\n                    </p>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs\">\n                      <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800\">\n                        <span className=\"text-slate-500 block mb-0.5\">Categorized Category:</span>\n                        <span className=\"font-semibold text-white\">{aiAnalysis.category}</span>\n                      </div>\n                      <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800\">\n                        <span className=\"text-slate-500 block mb-0.5\">Assessed Severity:</span>\n                        <span className=\"font-semibold text-white\">{aiAnalysis.severity}</span>\n                      </div>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Calculated Waste / Environmental Impact:</span>\n                      <p className=\"text-teal-300 font-medium leading-relaxed\">{aiAnalysis.wasteCaused}</p>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Repair Suggestion:</span>\n                      <p className=\"text-slate-300 leading-relaxed\">{aiAnalysis.repairSuggestion}</p>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Authenticity Verification Clues:</span>\n                      <p className=\"text-slate-400 leading-relaxed\">{aiAnalysis.authenticityClues}</p>\n                    </div>\n                  </div>\n                )}\n\n                {/* Manual Overrides Block */}\n                <div className=\"border-t border-slate-800/80 pt-4 space-y-4\">\n                  <h4 className=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Classification Overrides (Verify manually if required)</h4>\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-xs text-slate-500 mb-1\">Category</label>\n                      <select\n                        value={manualCategory}\n                        onChange={(e) => setManualCategory(e.target.value)}\n                        className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                      >\n                        <option value=\"Water Leakage\">Water Leakage</option>\n                        <option value=\"Pothole\">Pothole</option>\n                        <option value=\"Waste Management\">Waste Management</option>\n                        <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                        <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-xs text-slate-500 mb-1\">Severity Level</label>\n                      <select\n                        value={manualSeverity}\n                        onChange={(e) => setManualSeverity(e.target.value as any)}\n                        className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                      >\n                        <option value=\"Low\">Low</option>\n                        <option value=\"Medium\">Medium</option>\n                        <option value=\"High\">High</option>\n                        <option value=\"Critical\">Critical</option>\n                      </select>\n                    </div>\n                  </div>\n                  <div>\n                    <label className=\"block text-xs text-slate-500 mb-1\">Waste Footprint Description</label>\n                    <input\n                      type=\"text\"\n                      value={manualWaste}\n                      onChange={(e) => setManualWaste(e.target.value)}\n                      placeholder=\"e.g. 500 liters of water leaking daily, hazardous road blocks\"\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                    />\n                  </div>\n                </div>\n\n                {/* Form Action Buttons */}\n                <div className=\"flex gap-3 pt-4 border-t border-slate-800/80 justify-end\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setReportTitle(\"\");\n                      setReportDesc(\"\");\n                      setAiAnalysis(null);\n                      setActiveTab(\"issues\");\n                    }}\n                    className=\"px-4 py-2 bg-slate-950 hover:bg-slate-800 rounded-lg text-sm text-slate-400\"\n                  >\n                    Cancel\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"flex items-center gap-1.5 bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold px-5 py-2 rounded-lg text-sm hover:brightness-110 active:scale-95 transition-all\"\n                  >\n                    <Send className=\"h-4 w-4\" />\n                    Publish Report\n                  </button>\n                </div>\n              </form>\n            </div>\n          )}\n\n          {/* TAB 3: MONTHLY RESIDENT WELL-BEING SURVEY (Resident only) */}\n          {activeTab === \"survey\" && (\n            <div className=\"space-y-6 max-w-xl mx-auto\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Monthly Citizen Feedback & Well-being</h2>\n                <p className=\"text-slate-400 text-sm\">Your ratings directly drive accountability metrics, which are publicized for future political voting scorecards.</p>\n              </div>\n\n              {surveySuccess ? (\n                <div className=\"bg-emerald-950/20 border border-emerald-500/30 p-6 rounded-2xl text-center space-y-4\">\n                  <CheckCircle2 className=\"h-12 w-12 text-emerald-400 mx-auto animate-bounce\" />\n                  <h3 className=\"font-bold text-xl text-white\">Feedback Submitted Successfully!</h3>\n                  <p className=\"text-slate-300 text-sm max-w-sm mx-auto\">Thank you. Your voice contributes to the public service delivery scorecard of the administration and neighborhood handymen.</p>\n                  <button\n                    onClick={() => setSurveySuccess(false)}\n                    className=\"bg-emerald-500 text-slate-950 px-4 py-2 rounded-lg text-xs font-bold transition-all hover:brightness-110\"\n                  >\n                    Submit New Survey Update\n                  </button>\n                </div>\n              ) : (\n                <form onSubmit={handleSurveySubmit} className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl space-y-5\">\n                  {surveyError && (\n                    <div className=\"p-3 bg-red-950/50 border border-red-500/30 rounded-lg text-xs text-red-300 flex items-center gap-2\">\n                      <AlertCircle className=\"h-4 w-4\" /> {surveyError}\n                    </div>\n                  )}\n\n                  <div className=\"p-4 bg-slate-950 rounded-xl space-y-1\">\n                    <span className=\"text-[10px] font-mono tracking-wider text-slate-500 uppercase\">ACTIVE PERIOD</span>\n                    <p className=\"text-sm text-teal-300 font-semibold flex items-center gap-1.5\">\n                      <Calendar className=\"h-4 w-4\" /> June 2026 Feedback Drive\n                    </p>\n                  </div>\n\n                  {/* Rating 1: Overall Happiness */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      1. Overall Community Well-being & Happiness (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyHappiness(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyHappiness === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val === 1 ? \"\360\237\230\236\" : val === 3 ? \"\360\237\230\220\" : val === 5 ? \"\360\237\244\251\" : \"\"} {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 2: Local Services */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      2. Public Services & Speed of Repairs (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyServices(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyServices === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 3: Road Quality */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      3. Road Infrastructure & Streetlights (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyRoads(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyRoads === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 4: Cleanliness */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      4. Cleanliness & Garbage Clearance (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyCleanliness(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyCleanliness === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Feedback Text */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                      Specific Suggestions / Comments\n                    </label>\n                    <textarea\n                      rows={3}\n                      value={surveyFeedback}\n                      onChange={(e) => setSurveyFeedback(e.target.value)}\n                      placeholder=\"Share what local authorities or plumbers can do better in your block...\"\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    className=\"w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold py-3 rounded-lg hover:brightness-110 transition-all text-sm\"\n                  >\n                    Submit Monthly Evaluation\n                  </button>\n                </form>\n              )}\n            </div>\n          )}\n\n          {/* TAB 4: CONTRACTOR WORKROOM (Contractor only) */}\n          {activeTab === \"contractor\" && (\n            <div className=\"space-y-6\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Contractor Workroom</h2>\n                <p className=\"text-slate-400 text-sm\">\n                  Welcome back, <strong>{user.name}</strong>. View neighborhood reports that match your trade specialty (\n                  <span className=\"text-teal-400 font-semibold\">{user.specialty}</span>) to accept jobs, estimate quotes, and claim resolution.\n                </p>\n              </div>\n\n              {/* Grid split: Assigned/Active jobs vs Open Trade Jobs */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                {/* Panel left: Assigned Jobs */}\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n                  <h3 className=\"font-bold text-base text-white flex items-center gap-2\">\n                    <Sliders className=\"h-4.5 w-4.5 text-teal-400\" /> My Current Assignments ({\n                      issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length\n                    })\n                  </h3>\n                  \n                  {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length === 0 ? (\n                    <p className=\"text-xs text-slate-500 py-6 text-center border border-dashed border-slate-800 rounded-xl\">You have no active assignments. Accept open jobs listed below!</p>\n                  ) : (\n                    <div className=\"space-y-3\">\n                      {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").map(job => (\n                        <div key={job.id} className=\"bg-slate-950 border border-slate-800 rounded-xl p-4 space-y-3\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 font-semibold\">\n                              {job.status}\n                            </span>\n                            <span className=\"text-slate-500 font-mono\">Est: ${job.priceQuote}</span>\n                          </div>\n\n                          <h4 className=\"font-semibold text-white text-sm\">{job.title}</h4>\n                          <p className=\"text-slate-400 text-xs leading-relaxed line-clamp-2\">{job.description}</p>\n                          <div className=\"text-[11px] bg-slate-900 p-2 rounded-lg text-slate-300\">\n                            <strong className=\"text-teal-400 block mb-0.5\">Resident location:</strong>\n                            House {job.reporterHouse} \342\200\242 {job.reporterName}\n                          </div>\n\n                          <div className=\"flex gap-2 pt-2 border-t border-slate-800/60\">\n                            {job.status === \"Assigned\" && (\n                              <button\n                                onClick={() => handleStartProgress(job.id)}\n                                className=\"flex-1 bg-teal-500 text-slate-950 font-bold py-1.5 rounded-lg text-xs hover:bg-teal-400 transition-all\"\n                              >\n                                Start Work Progress\n                              </button>\n                            )}\n\n                            {job.status === \"In Progress\" && (\n                              <div className=\"w-full space-y-2\">\n                                <input\n                                  type=\"text\"\n                                  placeholder=\"Resolution notes (materials used, steps taken)...\"\n                                  value={resolutionNotesInput}\n                                  onChange={(e) => setResolutionNotesInput(e.target.value)}\n                                  className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2 text-xs text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                                />\n                                <button\n                                  onClick={() => handleResolveIssue(job.id)}\n                                  className=\"w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold py-1.5 rounded-lg text-xs hover:brightness-110 transition-all\"\n                                >\n                                  Submit Resolution & Request Payout\n                                </button>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n\n                  {/* Panel sub section: Received payouts */}\n                  <div className=\"border-t border-slate-800 pt-4 space-y-3\">\n                    <h4 className=\"font-bold text-sm text-slate-300 flex items-center gap-1.5\">\n                      <DollarSign className=\"h-4 w-4 text-emerald-400\" /> Earnings & Payout Status\n                    </h4>\n                    <div className=\"bg-slate-950/50 p-3 rounded-xl border border-slate-800/80 space-y-2 text-xs\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Completed jobs paid:</span>\n                        <span className=\"text-emerald-400 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Pending administrative payout release:</span>\n                        <span className=\"text-amber-400 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && !i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Panel right: Open Jobs Matching Trade Specialty */}\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n                  <h3 className=\"font-bold text-base text-white flex items-center gap-2\">\n                    <CheckCircle className=\"h-4.5 w-4.5 text-blue-400\" /> Open Service Inquiries (Matching: {user.specialty})\n                  </h3>\n\n                  {issues.filter(\n                    i => !i.assignedContractorId && (\n                      (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                      (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                      (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                      (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                      (i.category === \"Public Infrastructure\")\n                    )\n                  ).length === 0 ? (\n                    <p className=\"text-xs text-slate-500 py-12 text-center border border-dashed border-slate-800 rounded-xl\">No open service requests are matching your specialty trade at the moment.</p>\n                  ) : (\n                    <div className=\"space-y-3\">\n                      {issues.filter(\n                        i => !i.assignedContractorId && (\n                          (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                          (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                          (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                          (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                          (i.category === \"Public Infrastructure\")\n                        )\n                      ).map(openJob => (\n                        <div key={openJob.id} className=\"bg-slate-950 border border-slate-800 rounded-xl p-4 space-y-3\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"font-semibold text-teal-400 font-mono text-[10px] uppercase\">\n                              {openJob.category}\n                            </span>\n                            <span className=\"text-slate-400 font-mono text-[10px]\">\n                              {openJob.upvotes.length} validations\n                            </span>\n                          </div>\n\n                          <h4 className=\"font-semibold text-white text-sm\">{openJob.title}</h4>\n                          <p className=\"text-slate-400 text-xs leading-relaxed\">{openJob.description}</p>\n                          <div className=\"text-[11px] bg-slate-900/40 p-2.5 rounded-lg text-slate-400 space-y-1\">\n                            <div><strong>Impact details:</strong> {openJob.wasteCaused}</div>\n                            <div><strong>Hours unattended:</strong> {openJob.daysUnattended * 24} hours unaddressed</div>\n                          </div>\n\n                          {selectedIssueForAction === openJob.id ? (\n                            <div className=\"bg-slate-900/90 border border-teal-500/20 p-3 rounded-lg space-y-3 animate-fadeIn\">\n                              <div>\n                                <label className=\"block text-[10px] text-slate-400 mb-1 font-bold uppercase tracking-wider\">My Price Quote ($ USD)</label>\n                                <input\n                                  type=\"number\"\n                                  value={priceQuoteInput}\n                                  onChange={(e) => setPriceQuoteInput(e.target.value)}\n                                  className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                                />\n                              </div>\n                              <div className=\"flex gap-2\">\n                                <button\n                                  onClick={() => setSelectedIssueForAction(null)}\n                                  className=\"flex-1 bg-slate-950 hover:bg-slate-800 rounded-lg py-1 text-xs text-slate-400\"\n                                >\n                                  Cancel\n                                </button>\n                                <button\n                                  onClick={() => handleAcceptAssignment(openJob.id)}\n                                  className=\"flex-1 bg-teal-500 text-slate-950 font-bold py-1 rounded-lg text-xs hover:bg-teal-400 transition-all\"\n                                >\n                                  Submit Bid & Accept\n                                </button>\n                              </div>\n                            </div>\n                          ) : (\n                            <button\n                              onClick={() => {\n                                setSelectedIssueForAction(openJob.id);\n                                setPriceQuoteInput(\"150\");\n                              }}\n                              className=\"w-full bg-slate-900 hover:bg-slate-800 border border-slate-800 text-teal-300 font-bold py-1.5 rounded-lg text-xs transition-all\"\n                            >\n                              Accept Job Assignment\n                            </button>\n                          )}\n                        </div>\n                      ))}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* TAB 5: GOVERNANCE & ANALYTICS DASHBOARD (Admin/Elected Official only) */}\n          {activeTab === \"admin-dashboard\" && (\n            <div className=\"space-y-6 animate-fadeIn\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Elected Official Command Center</h2>\n                <p className=\"text-slate-400 text-sm\">Monitor neighborhood status, contractor speed performance indices, and resident happiness surveys for future voting times.</p>\n              </div>\n\n              {/* Stat Bento Grids */}\n              <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">ACTIVE REQUESTS</span>\n                  <p className=\"text-3xl font-extrabold text-white mt-1 font-mono\">\n                    {issues.filter(i => i.status !== \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-teal-400 font-mono block mt-1\">Needs attention</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">RESOLVED JOBS</span>\n                  <p className=\"text-3xl font-extrabold text-emerald-400 mt-1 font-mono\">\n                    {issues.filter(i => i.status === \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Fixes completed</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">WELLBEING INDEX</span>\n                  <p className=\"text-3xl font-extrabold text-teal-400 mt-1 font-mono\">\n                    {adminSurveys.length > 0\n                      ? (adminSurveys.reduce((acc, s) => acc + s.overallHappiness, 0) / adminSurveys.length).toFixed(1)\n                      : \"4.2\"\n                    }/5.0\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Citizen approval</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">REVENUE RESOLUTION</span>\n                  <p className=\"text-3xl font-extrabold text-white mt-1 font-mono\">\n                    ${issues.filter(i => i.status === \"Resolved\").reduce((acc, i) => acc + (i.priceQuote || 0), 0)}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Local contractor payouts</span>\n                </div>\n              </div>\n\n              {/* Stat charts with recharts */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                {/* Chart 1: Category Distribution */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Issues Distribution by Category</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">No category data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <PieChart>\n                          <Pie\n                            data={getCategoryChartData()}\n                            cx=\"50%\"\n                            cy=\"50%\"\n                            innerRadius={60}\n                            outerRadius={80}\n                            paddingAngle={5}\n                            dataKey=\"value\"\n                          >\n                            {getCategoryChartData().map((entry, index) => (\n                              <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\n                            ))}\n                          </Pie>\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"11px\" }} />\n                        </PieChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 2: Status distribution */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Issue Lifespans & Status Overview</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">No status data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getStatusChartData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1e293b\" />\n                          <XAxis dataKey=\"name\" stroke=\"#64748b\" fontSize={11} />\n                          <YAxis stroke=\"#64748b\" fontSize={11} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Bar dataKey=\"count\" fill=\"#14b8a6\" radius={[4, 4, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 3: Resident surveys approval trend */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4 lg:col-span-2\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Resident Well-being and Infrastructure Approval Indices</h3>\n                  <div className=\"h-64\">\n                    {adminSurveys.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">Waiting for first monthly surveys to show trends.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getSurveyWellbeingData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1e293b\" />\n                          <XAxis dataKey=\"month\" stroke=\"#64748b\" fontSize={11} />\n                          <YAxis stroke=\"#64748b\" fontSize={11} domain={[0, 5]} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"11px\" }} />\n                          <Bar dataKey=\"Happiness\" fill=\"#14b8a6\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Service Delivery\" fill=\"#3b82f6\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Road Safety\" fill=\"#f59e0b\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Sanitation\" fill=\"#10b981\" radius={[4, 4, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              {/* Interactive Contractor Invoices & Payments Section */}\n              <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                <h3 className=\"font-bold text-base text-white flex items-center gap-1.5\">\n                  <DollarSign className=\"h-5 w-5 text-emerald-400\" /> Pending Contractor Payments & Public Budget Releases\n                </h3>\n\n                {issues.filter(i => i.status === \"Resolved\").length === 0 ? (\n                  <p className=\"text-xs text-slate-500 py-6 text-center border border-dashed border-slate-800 rounded-xl\">No completed handyman resolutions require payment releases at this hour.</p>\n                ) : (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-left border-collapse text-xs\">\n                      <thead>\n                        <tr className=\"border-b border-slate-800 text-slate-400 font-semibold bg-slate-950/40\">\n                          <th className=\"p-3\">Issue ID</th>\n                          <th className=\"p-3\">Title / Resolution</th>\n                          <th className=\"p-3\">Assigned Handyman</th>\n                          <th className=\"p-3\">Estimated Quote</th>\n                          <th className=\"p-3\">Payment Status</th>\n                          <th className=\"p-3 text-right\">Action</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-slate-800/60\">\n                        {issues.filter(i => i.status === \"Resolved\").map(completedIssue => (\n                          <tr key={completedIssue.id} className=\"hover:bg-slate-950/20 transition-all\">\n                            <td className=\"p-3 font-mono text-slate-500\">{completedIssue.id}</td>\n                            <td className=\"p-3 max-w-xs\">\n                              <span className=\"font-bold text-slate-200 block\">{completedIssue.title}</span>\n                              <span className=\"text-slate-400 text-[11px] block mt-0.5 italic\">\342\200\234{completedIssue.resolutionNotes}\342\200\235</span>\n                            </td>\n                            <td className=\"p-3 text-teal-300 font-semibold\">{completedIssue.assignedContractorName}</td>\n                            <td className=\"p-3 font-mono font-bold text-slate-200\">${completedIssue.priceQuote}</td>\n                            <td className=\"p-3\">\n                              {completedIssue.isPaid ? (\n                                <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 font-bold\">\n                                  Released\n                                </span>\n                              ) : (\n                                <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 font-bold\">\n                                  Pending Review\n                                </span>\n                              )}\n                            </td>\n                            <td className=\"p-3 text-right\">\n                              {!completedIssue.isPaid && (\n                                <button\n                                  onClick={() => handleReleasePayment(completedIssue.id)}\n                                  className=\"bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold py-1 px-2.5 rounded text-[11px] transition-all\"\n                                >\n                                  Release Payout\n                                </button>\n                              )}\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </div>\n            </div>\n          )}\n\n          {/* TAB 6: ADMIN RESIDENT WELL-BEING INBOX (Admin only) */}\n          {activeTab === \"admin-surveys\" && (\n            <div className=\"space-y-6\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Resident Well-being inbox</h2>\n                <p className=\"text-slate-400 text-sm\">Review feedback surveys left by residents during monthly public satisfaction initiatives.</p>\n              </div>\n\n              {adminSurveys.length === 0 ? (\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center\">\n                  <MessageSquare className=\"h-10 w-10 text-slate-600 mx-auto mb-3\" />\n                  <h3 className=\"font-bold text-lg text-white\">Inbox is Empty</h3>\n                  <p className=\"text-slate-400 text-sm max-w-sm mx-auto mt-1\">There are no surveys or qualitative reports registered by citizens in the system yet.</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {adminSurveys.map((survey) => (\n                    <div key={survey.id} className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-3 flex flex-col justify-between\">\n                      <div>\n                        {/* Title line */}\n                        <div className=\"flex justify-between items-center pb-2 border-b border-slate-800/60\">\n                          <div>\n                            <span className=\"text-xs font-bold text-teal-400\">{survey.residentName}</span>\n                            <span className=\"text-[10px] text-slate-500 font-mono block\">Period: {survey.month}</span>\n                          </div>\n                          <span className=\"text-[10px] text-slate-500 font-mono\">{new Date(survey.date).toLocaleDateString()}</span>\n                        </div>\n\n                        {/* Ratings overview */}\n                        <div className=\"grid grid-cols-2 gap-2 text-xs pt-3\">\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Happiness:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.overallHappiness}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Services Speed:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.localServicesRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Road Quality:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.roadQualityRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Cleanliness:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.cleanlinessRating}/5</span>\n                          </div>\n                        </div>\n\n                        {/* Qualitative note */}\n                        {survey.feedbackText && (\n                          <div className=\"bg-slate-950/60 p-3 rounded-xl border border-slate-800/80 mt-3 text-xs leading-relaxed\">\n                            <strong className=\"text-slate-400 block mb-1\">Suggestions & Observations:</strong>\n                            <p className=\"text-slate-300\">\342\200\234{survey.feedbackText}\342\200\235</p>\n                          </div>\n                        )}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n        </main>\n      </div>\n\n      {/* Footer Info bar */}\n      <footer className=\"bg-slate-950 border-t border-slate-900 py-6 text-center text-xs text-slate-500 font-mono\">\n        <p>Community Hero Hyperlocal Problem Solver \302\251 2026. Empowering Neighborhood Transparency & Public Infrastructure Resolution.</p>\n      </footer>\n    </div>\n  );\n}\n"
    }
    diff {
      unified_diff {
        lines {
          text: "import React, { useState, useEffect } from \"react\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "import { User, Issue, Survey, Notification } from \"../types\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "import {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
