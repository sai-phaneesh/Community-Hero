ss\n            </label>\n            <input\n              type=\"email\"\n              required\n              value={email}\n              onChange={(e) => setEmail(e.target.value)}\n              placeholder=\"e.g. john@example.com\"\n              className=\"w-full bg-white border border-slate-300 rounded py-2 px-3 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500\"\n            />\n          </div>\n\n          {/* Password */}\n          <div>\n            <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n              Password\n            </label>\n            <input\n              type=\"password\"\n              required\n              value={password}\n              onChange={(e) => setPassword(e.target.value)}\n              placeholder=\"\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\342\200\242\"\n              className=\"w-full bg-white border border-slate-300 rounded py-2 px-3 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500\"\n            />\n          </div>\n\n          {/* Submit Button */}\n          <button\n            type=\"submit\"\n            disabled={loading}\n            className=\"w-full flex justify-center items-center gap-2 bg-slate-900 text-white font-semibold py-2.5 rounded hover:bg-slate-800 active:scale-[0.98] transition-all text-xs shadow-sm disabled:opacity-50 disabled:pointer-events-none mt-4\"\n          >\n            {loading ? (\n              <span className=\"h-4 w-4 border-2 border-white border-t-transparent rounded-full animate-spin\"></span>\n            ) : isRegister ? (\n              <>\n                <UserPlus className=\"h-3.5 w-3.5\" />\n                Create Account\n              </>\n            ) : (\n              <>\n                <LogIn className=\"h-3.5 w-3.5\" />\n                Sign In to Platform\n              </>\n            )}\n