      target_content: "        {/* Responsive Sidebar for Tab Selector */}\n        <aside className=\"w-full md:w-64 shrink-0 flex flex-col gap-2\">\n          <p className=\"text-[11px] font-semibold tracking-wider text-slate-500 uppercase px-3 mb-1\">Navigation Menu</p>\n          \n          {/* Universal tabs */}\n          <button\n            onClick={() => setActiveTab(\"issues\")}\n            className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n              activeTab === \"issues\"\n                ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n            }`}\n          >\n            <ClipboardList className=\"h-4.5 w-4.5\" />\n            Issues Hub\n          </button>\n\n          {/* Resident Specific Tabs */}\n          {user.role === \"resident\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"report\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"report\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <PlusCircle className=\"h-4.5 w-4.5\" />\n                Report New Issue\n              </button>\n              <button\n                onClick={() => setActiveTab(\"survey\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"survey\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <FileText className=\"h-4.5 w-4.5\" />\n                Monthly Well-being Survey\n              </button>\n            </>\n          )}\n\n          {/* Contractor Specific Tab */}\n          {user.role === \"contractor\" && (\n            <button\n              onClick={() => setActiveTab(\"contractor\")}\n              className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                activeTab === \"contractor\"\n                  ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                  : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n              }`}\n            >\n              <Sliders className=\"h-4.5 w-4.5\" />\n              Contractor Workroom\n            </button>\n          )}\n\n          {/* Admin Specific Tabs */}\n          {user.role === \"admin\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"admin-dashboard\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"admin-dashboard\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <TrendingUp className=\"h-4.5 w-4.5\" />\n                Governance & Analytics\n              </button>\n              <button\n                onClick={() => setActiveTab(\"admin-surveys\")}\n                className={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all ${\n                  activeTab === \"admin-surveys\"\n                    ? \"bg-teal-500 text-slate-950 font-semibold shadow-lg shadow-teal-500/10\"\n                    : \"text-slate-400 hover:text-white hover:bg-slate-900\"\n                }`}\n              >\n                <MessageSquare className=\"h-4.5 w-4.5\" />\n                Resident Well-being Inbox\n              </button>\n            </>\n          )}\n\n          {/* Hero Stats Card Widget */}\n          <div className=\"mt-6 bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left hidden md:block\">\n            <h4 className=\"text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3\">Community Statistics</h4>\n            <div className=\"space-y-2\">\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Unresolved Issues</span>\n                <span className=\"font-semibold text-amber-400 font-mono\">\n                  {issues.filter(i => i.status !== \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Resolved to Date</span>\n                <span className=\"font-semibold text-emerald-400 font-mono\">\n                  {issues.filter(i => i.status === \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-xs\">\n                <span className=\"text-slate-500\">Active Handymen</span>\n                <span className=\"font-semibold text-teal-400 font-mono\">5 Registered</span>\n              </div>\n            </div>\n          </div>\n        </aside>"
      replacement_content: "        {/* Responsive Sidebar for Tab Selector */}\n        <aside className=\"w-full md:w-64 shrink-0 flex flex-col gap-1.5\">\n          <p className=\"text-[10px] font-bold tracking-wider text-slate-500 uppercase px-2 mb-1\">Navigation Menu</p>\n          \n          {/* Universal tabs */}\n          <button\n            onClick={() => setActiveTab(\"issues\")}\n            className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n              activeTab === \"issues\"\n                ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n            }`}\n          >\n            <ClipboardList className=\"h-3.5 w-3.5\" />\n            Issues Hub\n          </button>\n\n          {/* Resident Specific Tabs */}\n          {user.role === \"resident\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"report\")}\n                className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n                  activeTab === \"report\"\n                    ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                    : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n                }`}\n              >\n                <PlusCircle className=\"h-3.5 w-3.5\" />\n                Report New Issue\n              </button>\n              <button\n                onClick={() => setActiveTab(\"survey\")}\n                className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n                  activeTab === \"survey\"\n                    ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                    : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n                }`}\n              >\n                <FileText className=\"h-3.5 w-3.5\" />\n                Monthly Well-being Survey\n              </button>\n            </>\n          )}\n\n          {/* Contractor Specific Tab */}\n          {user.role === \"contractor\" && (\n            <button\n              onClick={() => setActiveTab(\"contractor\")}\n              className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n                activeTab === \"contractor\"\n                  ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                  : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n              }`}\n            >\n              <Sliders className=\"h-3.5 w-3.5\" />\n              Contractor Workroom\n            </button>\n          )}\n\n          {/* Admin Specific Tabs */}\n          {user.role === \"admin\" && (\n            <>\n              <button\n                onClick={() => setActiveTab(\"admin-dashboard\")}\n                className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n                  activeTab === \"admin-dashboard\"\n                    ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                    : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n                }`}\n              >\n                <TrendingUp className=\"h-3.5 w-3.5\" />\n                Governance & Analytics\n              </button>\n              <button\n                onClick={() => setActiveTab(\"admin-surveys\")}\n                className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${\n                  activeTab === \"admin-surveys\"\n                    ? \"bg-slate-900 text-white border border-slate-700 shadow-sm\"\n                    : \"text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 border border-transparent\"\n                }`}\n              >\n                <MessageSquare className=\"h-3.5 w-3.5\" />\n                Resident Well-being Inbox\n              </button>\n            </>\n          )}\n\n          {/* Hero Stats Card Widget */}\n          <div className=\"mt-4 bg-white border border-slate-300 rounded p-3 text-left hidden md:block shadow-sm\">\n            <h4 className=\"text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2\">Community Statistics</h4>\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between items-center text-[11px]\">\n                <span className=\"text-slate-500\">Unresolved Issues</span>\n                <span className=\"font-bold text-slate-900 font-mono\">\n                  {issues.filter(i => i.status !== \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-[11px]\">\n                <span className=\"text-slate-500\">Resolved to Date</span>\n                <span className=\"font-bold text-slate-900 font-mono\">\n                  {issues.filter(i => i.status === \"Resolved\").length}\n                </span>\n              </div>\n              <div className=\"flex justify-between items-center text-[11px]\">\n                <span className=\"text-slate-500\">Active Handymen</span>\n                <span className=\"font-bold text-slate-900 font-mono\">5 Registered</span>\n              </div>\n            </div>\n          </div>\n        </aside>"
