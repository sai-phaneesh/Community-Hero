white\">Notifications Feed</h3>\n                  <button\n                    onClick={() => setShowNotifications(false)}\n                    className=\"text-xs text-slate-400 hover:text-teal-400\"\n                  >\n                    Close\n                  </button>\n                </div>\n                {notifications.length === 0 ? (\n                  <p className=\"text-xs text-slate-500 text-center py-4\">No notifications yet.</p>\n                ) : (\n                  <div className=\"space-y-2\">\n                    {notifications.map((notif) => (\n                      <div\n                        key={notif.id}\n                        onClick={() => handleMarkNotifRead(notif.id)}\n                        className={`p-2.5 rounded-lg border text-left cursor-pointer transition-all ${\n                          notif.read\n                            ? \"bg-slate-950/40 border-slate-900/40 text-slate-400\"\n                            : \"bg-teal-950/20 border-teal-500/30 text-slate-200 hover:border-teal-500/50\"\n                        }`}\n                      >\n                        <p className=\"text-xs font-semibold flex items-center gap-1\">\n                          {!notif.read && <span className=\"h-1.5 w-1.5 bg-teal-400 rounded-full shrink-0\"></span>}\n                          {notif.title}\n                        </p>\n                        <p className=\"text-[11px] mt-1 leading-relaxed\">{notif.message}</p>\n                        <span className=\"text-[9px] text-slate-500 font-mono block mt-1.5\">\n                          {new Date(notif.createdAt).toLocaleTimeString()}\n                        </span>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </div>\n            )}\n          </div>\n \n          {/* User Profile Info Tag */}\n          <div className=\"hidden md:flex flex-col items-end text-right\">\n            <span className=\"text-sm font-semibold text-white\">{user.name}</span>\n            <span className=\"text-xs text-teal-400 font-mono uppercase tracking-wider font-semibold\">\n              {user.role} {user.houseNumber ? `(House ${user.houseNumber})` : user.specialty ? `(${user.specialty})` : \"\"}\n            </span>\n          </div>\n \n          <button\n            onClick={onLogout}\n            className=\"p-2 text-slate-400 hover:text-rose-400 hover:bg-slate-800 rounded-lg transition-all\"\n            title=\"Log out\"\n          >\n            <LogOut className=\"h-5 w-5\" />\n          </button>\n        </div>\n      </header>\n \n      {/* Main Sub-Nav & Layout Container */}\n      <div className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row gap-6\">"
