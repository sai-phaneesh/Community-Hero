  file_change {
    absolute_path_uri: "file:///src/components/Dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "          {/* TAB 2: REPORT NEW ISSUE (Resident only) */}\n          {activeTab === \"report\" && (\n            <div className=\"space-y-6 max-w-2xl mx-auto\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Report a Hyperlocal Issue</h2>\n                <p className=\"text-slate-400 text-sm\">Provide details. Use our built-in Gemini AI audit tool to instantly categorize the issue and evaluate environmental waste impacts.</p>\n              </div>\n\n              <form onSubmit={handleReportSubmit} className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl space-y-5\">\n                {/* Title */}\n                <div>\n                  <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                    Issue Title / Summary\n                  </label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={reportTitle}\n                    onChange={(e) => setReportTitle(e.target.value)}\n                    placeholder=\"e.g. Broken water pipe leaking near central curb\"\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                  />\n                </div>\n\n                {/* Description */}\n                <div>\n                  <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                    Detailed Description\n                  </label>\n                  <textarea\n                    required\n                    rows={4}\n                    value={reportDesc}\n                    onChange={(e) => setReportDesc(e.target.value)}\n                    placeholder=\"Please specify exactly where the issue is, how long it\'s been active, and what kind of waste or risk it is generating...\"\n                    className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                  />\n                </div>\n\n                {/* AI Audit Activation Button */}\n                <div className=\"p-4 bg-teal-950/20 border border-teal-500/20 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3\">\n                  <div className=\"flex items-center gap-2\">\n                    <Sparkles className=\"h-5 w-5 text-teal-400 shrink-0 animate-bounce\" />\n                    <div>\n                      <p className=\"text-xs font-bold text-teal-300\">Gemini AI Category & Waste Auditor</p>\n                      <p className=\"text-[11px] text-slate-400 leading-relaxed\">Let AI automatically determine the category, severity level, and waste footprint.</p>\n                    </div>\n                  </div>\n                  <button\n                    type=\"button\"\n                    onClick={handleAiAnalyze}\n                    disabled={aiLoading}\n                    className=\"shrink-0 flex items-center gap-1 bg-teal-500 text-slate-950 font-bold px-3 py-1.5 rounded-lg text-xs hover:bg-teal-400 transition-all disabled:opacity-50\"\n                  >\n                    {aiLoading ? \"Auditing...\" : \"Run AI Audit\"}\n                  </button>\n                </div>\n\n                {/* AI Analysis Result Showcase */}\n                {aiAnalysis && (\n                  <div className=\"bg-slate-950 border border-teal-500/20 rounded-xl p-4 space-y-3 text-sm animate-fadeIn\">\n                    <p className=\"text-xs font-bold text-teal-400 uppercase tracking-widest flex items-center gap-1\">\n                      <CheckCircle2 className=\"h-4 w-4\" /> AI Evaluation Completed\n                    </p>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs\">\n                      <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800\">\n                        <span className=\"text-slate-500 block mb-0.5\">Categorized Category:</span>\n                        <span className=\"font-semibold text-white\">{aiAnalysis.category}</span>\n                      </div>\n                      <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800\">\n                        <span className=\"text-slate-500 block mb-0.5\">Assessed Severity:</span>\n                        <span className=\"font-semibold text-white\">{aiAnalysis.severity}</span>\n                      </div>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Calculated Waste / Environmental Impact:</span>\n                      <p className=\"text-teal-300 font-medium leading-relaxed\">{aiAnalysis.wasteCaused}</p>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Repair Suggestion:</span>\n                      <p className=\"text-slate-300 leading-relaxed\">{aiAnalysis.repairSuggestion}</p>\n                    </div>\n                    <div className=\"bg-slate-900 p-2.5 rounded-lg border border-slate-800 text-xs\">\n                      <span className=\"text-slate-500 block mb-0.5\">Authenticity Verification Clues:</span>\n                      <p className=\"text-slate-400 leading-relaxed\">{aiAnalysis.authenticityClues}</p>\n                    </div>\n                  </div>\n                )}\n\n                {/* Manual Overrides Block */}\n                <div className=\"border-t border-slate-800/80 pt-4 space-y-4\">\n                  <h4 className=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Classification Overrides (Verify manually if required)</h4>\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-xs text-slate-500 mb-1\">Category</label>\n                      <select\n                        value={manualCategory}\n                        onChange={(e) => setManualCategory(e.target.value)}\n                        className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                      >\n                        <option value=\"Water Leakage\">Water Leakage</option>\n                        <option value=\"Pothole\">Pothole</option>\n                        <option value=\"Waste Management\">Waste Management</option>\n                        <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                        <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-xs text-slate-500 mb-1\">Severity Level</label>\n                      <select\n                        value={manualSeverity}\n                        onChange={(e) => setManualSeverity(e.target.value as any)}\n                        className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                      >\n                        <option value=\"Low\">Low</option>\n                        <option value=\"Medium\">Medium</option>\n                        <option value=\"High\">High</option>\n                        <option value=\"Critical\">Critical</option>\n                      </select>\n                    </div>\n                  </div>\n                  <div>\n                    <label className=\"block text-xs text-slate-500 mb-1\">Waste Footprint Description</label>\n                    <input\n                      type=\"text\"\n                      value={manualWaste}\n                      onChange={(e) => setManualWaste(e.target.value)}\n                      placeholder=\"e.g. 500 liters of water leaking daily, hazardous road blocks\"\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-lg py-2 px-3 text-slate-300 text-sm focus:outline-none\"\n                    />\n                  </div>\n                </div>\n\n                {/* Form Action Buttons */}\n                <div className=\"flex gap-3 pt-4 border-t border-slate-800/80 justify-end\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setReportTitle(\"\");\n                      setReportDesc(\"\");\n                      setAiAnalysis(null);\n                      setActiveTab(\"issues\");\n                    }}\n                    className=\"px-4 py-2 bg-slate-950 hover:bg-slate-800 rounded-lg text-sm text-slate-400\"\n                  >\n                    Cancel\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"flex items-center gap-1.5 bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold px-5 py-2 rounded-lg text-sm hover:brightness-110 active:scale-95 transition-all\"\n                  >\n                    <Send className=\"h-4 w-4\" />\n                    Publish Report\n                  </button>\n                </div>\n              </form>\n            </div>\n          )}\n\n          {/* TAB 3: MONTHLY RESIDENT WELL-BEING SURVEY (Resident only) */}\n          {activeTab === \"survey\" && (\n            <div className=\"space-y-6 max-w-xl mx-auto\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Monthly Citizen Feedback & Well-being</h2>\n                <p className=\"text-slate-400 text-sm\">Your ratings directly drive accountability metrics, which are publicized for future political voting scorecards.</p>\n              </div>\n\n              {surveySuccess ? (\n                <div className=\"bg-emerald-950/20 border border-emerald-500/30 p-6 rounded-2xl text-center space-y-4\">\n                  <CheckCircle2 className=\"h-12 w-12 text-emerald-400 mx-auto animate-bounce\" />\n                  <h3 className=\"font-bold text-xl text-white\">Feedback Submitted Successfully!</h3>\n                  <p className=\"text-slate-300 text-sm max-w-sm mx-auto\">Thank you. Your voice contributes to the public service delivery scorecard of the administration and neighborhood handymen.</p>\n                  <button\n                    onClick={() => setSurveySuccess(false)}\n                    className=\"bg-emerald-500 text-slate-950 px-4 py-2 rounded-lg text-xs font-bold transition-all hover:brightness-110\"\n                  >\n                    Submit New Survey Update\n                  </button>\n                </div>\n              ) : (\n                <form onSubmit={handleSurveySubmit} className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl space-y-5\">\n                  {surveyError && (\n                    <div className=\"p-3 bg-red-950/50 border border-red-500/30 rounded-lg text-xs text-red-300 flex items-center gap-2\">\n                      <AlertCircle className=\"h-4 w-4\" /> {surveyError}\n                    </div>\n                  )}\n\n                  <div className=\"p-4 bg-slate-950 rounded-xl space-y-1\">\n                    <span className=\"text-[10px] font-mono tracking-wider text-slate-500 uppercase\">ACTIVE PERIOD</span>\n                    <p className=\"text-sm text-teal-300 font-semibold flex items-center gap-1.5\">\n                      <Calendar className=\"h-4 w-4\" /> June 2026 Feedback Drive\n                    </p>\n                  </div>\n\n                  {/* Rating 1: Overall Happiness */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      1. Overall Community Well-being & Happiness (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyHappiness(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyHappiness === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val === 1 ? \"\360\237\230\236\" : val === 3 ? \"\360\237\230\220\" : val === 5 ? \"\360\237\244\251\" : \"\"} {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 2: Local Services */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      2. Public Services & Speed of Repairs (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyServices(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyServices === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 3: Road Quality */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      3. Road Infrastructure & Streetlights (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyRoads(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyRoads === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 4: Cleanliness */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2\">\n                      4. Cleanliness & Garbage Clearance (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyCleanliness(val)}\n                          className={`flex-1 py-3 text-sm font-bold rounded-lg border transition-all ${\n                            surveyCleanliness === val\n                              ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                              : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Feedback Text */}\n                  <div>\n                    <label className=\"block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5\">\n                      Specific Suggestions / Comments\n                    </label>\n                    <textarea\n                      rows={3}\n                      value={surveyFeedback}\n                      onChange={(e) => setSurveyFeedback(e.target.value)}\n                      placeholder=\"Share what local authorities or plumbers can do better in your block...\"\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl py-2.5 px-3.5 text-white placeholder-slate-600 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    className=\"w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold py-3 rounded-lg hover:brightness-110 transition-all text-sm\"\n                  >\n                    Submit Monthly Evaluation\n                  </button>\n                </form>\n              )}\n            </div>\n          )}\n\n          {/* TAB 4: CONTRACTOR WORKROOM (Contractor only) */}\n          {activeTab === \"contractor\" && (\n            <div className=\"space-y-6\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Contractor Workroom</h2>\n                <p className=\"text-slate-400 text-sm\">\n                  Welcome back, <strong>{user.name}</strong>. View neighborhood reports that match your trade specialty (\n                  <span className=\"text-teal-400 font-semibold\">{user.specialty}</span>) to accept jobs, estimate quotes, and claim resolution.\n                </p>\n              </div>\n\n              {/* Grid split: Assigned/Active jobs vs Open Trade Jobs */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                {/* Panel left: Assigned Jobs */}\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n                  <h3 className=\"font-bold text-base text-white flex items-center gap-2\">\n                    <Sliders className=\"h-4.5 w-4.5 text-teal-400\" /> My Current Assignments ({\n                      issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length\n                    })\n                  </h3>\n                  \n                  {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length === 0 ? (\n                    <p className=\"text-xs text-slate-500 py-6 text-center border border-dashed border-slate-800 rounded-xl\">You have no active assignments. Accept open jobs listed below!</p>\n                  ) : (\n                    <div className=\"space-y-3\">\n                      {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").map(job => (\n                        <div key={job.id} className=\"bg-slate-950 border border-slate-800 rounded-xl p-4 space-y-3\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 font-semibold\">\n                              {job.status}\n                            </span>\n                            <span className=\"text-slate-500 font-mono\">Est: ${job.priceQuote}</span>\n                          </div>\n\n                          <h4 className=\"font-semibold text-white text-sm\">{job.title}</h4>\n                          <p className=\"text-slate-400 text-xs leading-relaxed line-clamp-2\">{job.description}</p>\n                          <div className=\"text-[11px] bg-slate-900 p-2 rounded-lg text-slate-300\">\n                            <strong className=\"text-teal-400 block mb-0.5\">Resident location:</strong>\n                            House {job.reporterHouse} \342\200\242 {job.reporterName}\n                          </div>\n\n                          <div className=\"flex gap-2 pt-2 border-t border-slate-800/60\">\n                            {job.status === \"Assigned\" && (\n                              <button\n                                onClick={() => handleStartProgress(job.id)}\n                                className=\"flex-1 bg-teal-500 text-slate-950 font-bold py-1.5 rounded-lg text-xs hover:bg-teal-400 transition-all\"\n                              >\n                                Start Work Progress\n                              </button>\n                            )}\n\n                            {job.status === \"In Progress\" && (\n                              <div className=\"w-full space-y-2\">\n                                <input\n                                  type=\"text\"\n                                  placeholder=\"Resolution notes (materials used, steps taken)...\"\n                                  value={resolutionNotesInput}\n                                  onChange={(e) => setResolutionNotesInput(e.target.value)}\n                                  className=\"w-full bg-slate-900 border border-slate-800 rounded-lg p-2 text-xs text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                                />\n                                <button\n                                  onClick={() => handleResolveIssue(job.id)}\n                                  className=\"w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-slate-950 font-bold py-1.5 rounded-lg text-xs hover:brightness-110 transition-all\"\n                                >\n                                  Submit Resolution & Request Payout\n                                </button>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n\n                  {/* Panel sub section: Received payouts */}\n                  <div className=\"border-t border-slate-800 pt-4 space-y-3\">\n                    <h4 className=\"font-bold text-sm text-slate-300 flex items-center gap-1.5\">\n                      <DollarSign className=\"h-4 w-4 text-emerald-400\" /> Earnings & Payout Status\n                    </h4>\n                    <div className=\"bg-slate-950/50 p-3 rounded-xl border border-slate-800/80 space-y-2 text-xs\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Completed jobs paid:</span>\n                        <span className=\"text-emerald-400 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Pending administrative payout release:</span>\n                        <span className=\"text-amber-400 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && !i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Panel right: Open Jobs Matching Trade Specialty */}\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n                  <h3 className=\"font-bold text-base text-white flex items-center gap-2\">\n                    <CheckCircle className=\"h-4.5 w-4.5 text-blue-400\" /> Open Service Inquiries (Matching: {user.specialty})\n                  </h3>\n\n                  {issues.filter(\n                    i => !i.assignedContractorId && (\n                      (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                      (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                      (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                      (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                      (i.category === \"Public Infrastructure\")\n                    )\n                  ).length === 0 ? (\n                    <p className=\"text-xs text-slate-500 py-12 text-center border border-dashed border-slate-800 rounded-xl\">No open service requests are matching your specialty trade at the moment.</p>\n                  ) : (\n                    <div className=\"space-y-3\">\n                      {issues.filter(\n                        i => !i.assignedContractorId && (\n                          (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                          (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                          (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                          (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                          (i.category === \"Public Infrastructure\")\n                        )\n                      ).map(openJob => (\n                        <div key={openJob.id} className=\"bg-slate-950 border border-slate-800 rounded-xl p-4 space-y-3\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"font-semibold text-teal-400 font-mono text-[10px] uppercase\">\n                              {openJob.category}\n                            </span>\n                            <span className=\"text-slate-400 font-mono text-[10px]\">\n                              {openJob.upvotes.length} validations\n                            </span>\n                          </div>\n\n                          <h4 className=\"font-semibold text-white text-sm\">{openJob.title}</h4>\n                          <p className=\"text-slate-400 text-xs leading-relaxed\">{openJob.description}</p>\n                          <div className=\"text-[11px] bg-slate-900/40 p-2.5 rounded-lg text-slate-400 space-y-1\">\n                            <div><strong>Impact details:</strong> {openJob.wasteCaused}</div>\n                            <div><strong>Hours unattended:</strong> {openJob.daysUnattended * 24} hours unaddressed</div>\n                          </div>\n\n                          {selectedIssueForAction === openJob.id ? (\n                            <div className=\"bg-slate-900/90 border border-teal-500/20 p-3 rounded-lg space-y-3 animate-fadeIn\">\n                              <div>\n                                <label className=\"block text-[10px] text-slate-400 mb-1 font-bold uppercase tracking-wider\">My Price Quote ($ USD)</label>\n                                <input\n                                  type=\"number\"\n                                  value={priceQuoteInput}\n                                  onChange={(e) => setPriceQuoteInput(e.target.value)}\n                                  className=\"w-full bg-slate-950 border border-slate-800 rounded-lg p-2 text-xs text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                                />\n                              </div>\n                              <div className=\"flex gap-2\">\n                                <button\n                                  onClick={() => setSelectedIssueForAction(null)}\n                                  className=\"flex-1 bg-slate-950 hover:bg-slate-800 rounded-lg py-1 text-xs text-slate-400\"\n                                >\n                                  Cancel\n                                </button>\n                                <button\n                                  onClick={() => handleAcceptAssignment(openJob.id)}\n                                  className=\"flex-1 bg-teal-500 text-slate-950 font-bold py-1 rounded-lg text-xs hover:bg-teal-400 transition-all\"\n                                >\n                                  Submit Bid & Accept\n                                </button>\n                              </div>\n                            </div>\n                          ) : (\n                            <button\n                              onClick={() => {\n                                setSelectedIssueForAction(openJob.id);\n                                setPriceQuoteInput(\"150\");\n                              }}\n                              className=\"w-full bg-slate-900 hover:bg-slate-800 border border-slate-800 text-teal-300 font-bold py-1.5 rounded-lg text-xs transition-all\"\n                            >\n                              Accept Job Assignment\n                            </button>\n                          )}\n                        </div>\n                      ))}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* TAB 5: GOVERNANCE & ANALYTICS DASHBOARD (Admin/Elected Official only) */}\n          {activeTab === \"admin-dashboard\" && (\n            <div className=\"space-y-6 animate-fadeIn\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Elected Official Command Center</h2>\n                <p className=\"text-slate-400 text-sm\">Monitor neighborhood status, contractor speed performance indices, and resident happiness surveys for future voting times.</p>\n              </div>\n\n              {/* Stat Bento Grids */}\n              <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">ACTIVE REQUESTS</span>\n                  <p className=\"text-3xl font-extrabold text-white mt-1 font-mono\">\n                    {issues.filter(i => i.status !== \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-teal-400 font-mono block mt-1\">Needs attention</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">RESOLVED JOBS</span>\n                  <p className=\"text-3xl font-extrabold text-emerald-400 mt-1 font-mono\">\n                    {issues.filter(i => i.status === \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Fixes completed</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">WELLBEING INDEX</span>\n                  <p className=\"text-3xl font-extrabold text-teal-400 mt-1 font-mono\">\n                    {adminSurveys.length > 0\n                      ? (adminSurveys.reduce((acc, s) => acc + s.overallHappiness, 0) / adminSurveys.length).toFixed(1)\n                      : \"4.2\"\n                    }/5.0\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Citizen approval</span>\n                </div>\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-4 text-left\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">REVENUE RESOLUTION</span>\n                  <p className=\"text-3xl font-extrabold text-white mt-1 font-mono\">\n                    ${issues.filter(i => i.status === \"Resolved\").reduce((acc, i) => acc + (i.priceQuote || 0), 0)}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-mono block mt-1\">Local contractor payouts</span>\n                </div>\n              </div>\n\n              {/* Stat charts with recharts */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                {/* Chart 1: Category Distribution */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Issues Distribution by Category</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">No category data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <PieChart>\n                          <Pie\n                            data={getCategoryChartData()}\n                            cx=\"50%\"\n                            cy=\"50%\"\n                            innerRadius={60}\n                            outerRadius={80}\n                            paddingAngle={5}\n                            dataKey=\"value\"\n                          >\n                            {getCategoryChartData().map((entry, index) => (\n                              <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\n                            ))}\n                          </Pie>\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"11px\" }} />\n                        </PieChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 2: Status distribution */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Issue Lifespans & Status Overview</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">No status data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getStatusChartData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1e293b\" />\n                          <XAxis dataKey=\"name\" stroke=\"#64748b\" fontSize={11} />\n                          <YAxis stroke=\"#64748b\" fontSize={11} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Bar dataKey=\"count\" fill=\"#14b8a6\" radius={[4, 4, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 3: Resident surveys approval trend */}\n                <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4 lg:col-span-2\">\n                  <h3 className=\"font-bold text-sm text-slate-300\">Resident Well-being and Infrastructure Approval Indices</h3>\n                  <div className=\"h-64\">\n                    {adminSurveys.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-500\">Waiting for first monthly surveys to show trends.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getSurveyWellbeingData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#1e293b\" />\n                          <XAxis dataKey=\"month\" stroke=\"#64748b\" fontSize={11} />\n                          <YAxis stroke=\"#64748b\" fontSize={11} domain={[0, 5]} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#0f172a\", border: \"1px solid #334155\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"11px\" }} />\n                          <Bar dataKey=\"Happiness\" fill=\"#14b8a6\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Service Delivery\" fill=\"#3b82f6\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Road Safety\" fill=\"#f59e0b\" radius={[4, 4, 0, 0]} />\n                          <Bar dataKey=\"Sanitation\" fill=\"#10b981\" radius={[4, 4, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              {/* Interactive Contractor Invoices & Payments Section */}\n              <div className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-4\">\n                <h3 className=\"font-bold text-base text-white flex items-center gap-1.5\">\n                  <DollarSign className=\"h-5 w-5 text-emerald-400\" /> Pending Contractor Payments & Public Budget Releases\n                </h3>\n\n                {issues.filter(i => i.status === \"Resolved\").length === 0 ? (\n                  <p className=\"text-xs text-slate-500 py-6 text-center border border-dashed border-slate-800 rounded-xl\">No completed handyman resolutions require payment releases at this hour.</p>\n                ) : (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-left border-collapse text-xs\">\n                      <thead>\n                        <tr className=\"border-b border-slate-800 text-slate-400 font-semibold bg-slate-950/40\">\n                          <th className=\"p-3\">Issue ID</th>\n                          <th className=\"p-3\">Title / Resolution</th>\n                          <th className=\"p-3\">Assigned Handyman</th>\n                          <th className=\"p-3\">Estimated Quote</th>\n                          <th className=\"p-3\">Payment Status</th>\n                          <th className=\"p-3 text-right\">Action</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-slate-800/60\">\n                        {issues.filter(i => i.status === \"Resolved\").map(completedIssue => (\n                          <tr key={completedIssue.id} className=\"hover:bg-slate-950/20 transition-all\">\n                            <td className=\"p-3 font-mono text-slate-500\">{completedIssue.id}</td>\n                            <td className=\"p-3 max-w-xs\">\n                              <span className=\"font-bold text-slate-200 block\">{completedIssue.title}</span>\n                              <span className=\"text-slate-400 text-[11px] block mt-0.5 italic\">\342\200\234{completedIssue.resolutionNotes}\342\200\235</span>\n                            </td>\n                            <td className=\"p-3 text-teal-300 font-semibold\">{completedIssue.assignedContractorName}</td>\n                            <td className=\"p-3 font-mono font-bold text-slate-200\">${completedIssue.priceQuote}</td>\n                            <td className=\"p-3\">\n                              {completedIssue.isPaid ? (\n                                <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 font-bold\">\n                                  Released\n                                </span>\n                              ) : (\n                                <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 font-bold\">\n                                  Pending Review\n                                </span>\n                              )}\n                            </td>\n                            <td className=\"p-3 text-right\">\n                              {!completedIssue.isPaid && (\n                                <button\n                                  onClick={() => handleReleasePayment(completedIssue.id)}\n                                  className=\"bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold py-1 px-2.5 rounded text-[11px] transition-all\"\n                                >\n                                  Release Payout\n                                </button>\n                              )}\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </div>\n            </div>\n          )}\n\n          {/* TAB 6: ADMIN RESIDENT WELL-BEING INBOX (Admin only) */}\n          {activeTab === \"admin-surveys\" && (\n            <div className=\"space-y-6\">\n              <div>\n                <h2 className=\"text-2xl font-bold tracking-tight text-white\">Resident Well-being inbox</h2>\n                <p className=\"text-slate-400 text-sm\">Review feedback surveys left by residents during monthly public satisfaction initiatives.</p>\n              </div>\n\n              {adminSurveys.length === 0 ? (\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center\">\n                  <MessageSquare className=\"h-10 w-10 text-slate-600 mx-auto mb-3\" />\n                  <h3 className=\"font-bold text-lg text-white\">Inbox is Empty</h3>\n                  <p className=\"text-slate-400 text-sm max-w-sm mx-auto mt-1\">There are no surveys or qualitative reports registered by citizens in the system yet.</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {adminSurveys.map((survey) => (\n                    <div key={survey.id} className=\"bg-slate-900 border border-slate-800 p-5 rounded-2xl space-y-3 flex flex-col justify-between\">\n                      <div>\n                        {/* Title line */}\n                        <div className=\"flex justify-between items-center pb-2 border-b border-slate-800/60\">\n                          <div>\n                            <span className=\"text-xs font-bold text-teal-400\">{survey.residentName}</span>\n                            <span className=\"text-[10px] text-slate-500 font-mono block\">Period: {survey.month}</span>\n                          </div>\n                          <span className=\"text-[10px] text-slate-500 font-mono\">{new Date(survey.date).toLocaleDateString()}</span>\n                        </div>\n\n                        {/* Ratings overview */}\n                        <div className=\"grid grid-cols-2 gap-2 text-xs pt-3\">\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Happiness:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.overallHappiness}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Services Speed:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.localServicesRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Road Quality:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.roadQualityRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-950/60 p-2 rounded-lg flex justify-between items-center border border-slate-900\">\n                            <span className=\"text-slate-500\">Cleanliness:</span>\n                            <span className=\"font-bold text-white font-mono\">{survey.cleanlinessRating}/5</span>\n                          </div>\n                        </div>\n\n                        {/* Qualitative note */}\n                        {survey.feedbackText && (\n                          <div className=\"bg-slate-950/60 p-3 rounded-xl border border-slate-800/80 mt-3 text-xs leading-relaxed\">\n                            <strong className=\"text-slate-400 block mb-1\">Suggestions & Observations:</strong>\n                            <p className=\"text-slate-300\">\342\200\234{survey.feedbackText}\342\200\235</p>\n                          </div>\n                        )}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n        </main>\n      </div>\n\n      {/* Footer Info bar */}\n      <footer className=\"bg-slate-950 border-t border-slate-900 py-6 text-center text-xs text-slate-500 font-mono\">\n        <p>Community Hero Hyperlocal Problem Solver \302\251 2026. Empowering Neighborhood Transparency & Public Infrastructure Resolution.</p>\n      </footer>\n    </div>\n  );\n}"
      replacement_content: "          {/* TAB 2: REPORT NEW ISSUE (Resident only) */}\n          {activeTab === \"report\" && (\n            <div className=\"space-y-4 max-w-2xl mx-auto\">\n              <div>\n                <h2 className=\"text-base font-bold tracking-tight text-slate-900\">Report a Hyperlocal Issue</h2>\n                <p className=\"text-slate-500 text-xs mt-0.5 font-sans\">Provide details. Use our built-in Gemini AI audit tool to instantly categorize the issue and evaluate environmental waste impacts.</p>\n              </div>\n\n              <form onSubmit={handleReportSubmit} className=\"bg-white border border-slate-300 p-5 rounded space-y-4 shadow-sm\">\n                {/* Title */}\n                <div>\n                  <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                    Issue Title / Summary\n                  </label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={reportTitle}\n                    onChange={(e) => setReportTitle(e.target.value)}\n                    placeholder=\"e.g. Broken water pipe leaking near central curb\"\n                    className=\"w-full bg-slate-50 border border-slate-300 rounded py-1.5 px-2.5 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                  />\n                </div>\n\n                {/* Description */}\n                <div>\n                  <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                    Detailed Description\n                  </label>\n                  <textarea\n                    required\n                    rows={3}\n                    value={reportDesc}\n                    onChange={(e) => setReportDesc(e.target.value)}\n                    placeholder=\"Please specify exactly where the issue is, how long it\'s been active, and what kind of waste or risk it is generating...\"\n                    className=\"w-full bg-slate-50 border border-slate-300 rounded py-1.5 px-2.5 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                  />\n                </div>\n\n                {/* AI Audit Activation Button */}\n                <div className=\"p-3 bg-emerald-50 border border-emerald-200 rounded flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3\">\n                  <div className=\"flex items-center gap-2\">\n                    <Sparkles className=\"h-4.5 w-4.5 text-emerald-600 shrink-0\" />\n                    <div>\n                      <p className=\"text-xs font-bold text-emerald-800\">Gemini AI Category & Waste Auditor</p>\n                      <p className=\"text-[11px] text-slate-600 leading-normal\">Let AI automatically determine the category, severity level, and waste footprint.</p>\n                    </div>\n                  </div>\n                  <button\n                    type=\"button\"\n                    onClick={handleAiAnalyze}\n                    disabled={aiLoading}\n                    className=\"shrink-0 flex items-center gap-1 bg-slate-900 text-white font-bold px-2.5 py-1 rounded text-xs hover:bg-slate-800 transition-all disabled:opacity-50 cursor-pointer shadow-sm\"\n                  >\n                    {aiLoading ? \"Auditing...\" : \"Run AI Audit\"}\n                  </button>\n                </div>\n\n                {/* AI Analysis Result Showcase */}\n                {aiAnalysis && (\n                  <div className=\"bg-emerald-50/40 border border-emerald-300/40 rounded p-3 space-y-2.5 text-xs animate-fadeIn\">\n                    <p className=\"text-[10px] font-bold text-emerald-700 uppercase tracking-wider flex items-center gap-1\">\n                      <CheckCircle2 className=\"h-3.5 w-3.5\" /> AI Evaluation Completed\n                    </p>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs\">\n                      <div className=\"bg-white p-2 rounded border border-slate-200\">\n                        <span className=\"text-slate-500 text-[10px] block mb-0.5\">Categorized Category:</span>\n                        <span className=\"font-bold text-slate-900\">{aiAnalysis.category}</span>\n                      </div>\n                      <div className=\"bg-white p-2 rounded border border-slate-200\">\n                        <span className=\"text-slate-500 text-[10px] block mb-0.5\">Assessed Severity:</span>\n                        <span className=\"font-bold text-slate-900\">{aiAnalysis.severity}</span>\n                      </div>\n                    </div>\n                    <div className=\"bg-white p-2 rounded border border-slate-200 text-xs\">\n                      <span className=\"text-slate-500 text-[10px] block mb-0.5\">Calculated Waste / Environmental Impact:</span>\n                      <p className=\"text-emerald-700 font-semibold leading-relaxed font-mono text-[11px]\">{aiAnalysis.wasteCaused}</p>\n                    </div>\n                    <div className=\"bg-white p-2 rounded border border-slate-200 text-xs\">\n                      <span className=\"text-slate-500 text-[10px] block mb-0.5\">Repair Suggestion:</span>\n                      <p className=\"text-slate-700 leading-normal\">{aiAnalysis.repairSuggestion}</p>\n                    </div>\n                    <div className=\"bg-white p-2 rounded border border-slate-200 text-xs\">\n                      <span className=\"text-slate-500 text-[10px] block mb-0.5\">Authenticity Verification Clues:</span>\n                      <p className=\"text-slate-600 leading-normal\">{aiAnalysis.authenticityClues}</p>\n                    </div>\n                  </div>\n                )}\n\n                {/* Manual Overrides Block */}\n                <div className=\"border-t border-slate-200 pt-3 space-y-3\">\n                  <h4 className=\"text-[10px] font-bold text-slate-500 uppercase tracking-wider\">Classification Overrides (Verify manually if required)</h4>\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n                    <div>\n                      <label className=\"block text-[10px] text-slate-500 mb-0.5\">Category</label>\n                      <select\n                        value={manualCategory}\n                        onChange={(e) => setManualCategory(e.target.value)}\n                        className=\"w-full bg-slate-50 border border-slate-300 rounded py-1 px-2 text-slate-800 text-xs focus:outline-none focus:border-slate-500\"\n                      >\n                        <option value=\"Water Leakage\">Water Leakage</option>\n                        <option value=\"Pothole\">Pothole</option>\n                        <option value=\"Waste Management\">Waste Management</option>\n                        <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                        <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-[10px] text-slate-500 mb-0.5\">Severity Level</label>\n                      <select\n                        value={manualSeverity}\n                        onChange={(e) => setManualSeverity(e.target.value as any)}\n                        className=\"w-full bg-slate-50 border border-slate-300 rounded py-1 px-2 text-slate-800 text-xs focus:outline-none focus:border-slate-500\"\n                      >\n                        <option value=\"Low\">Low</option>\n                        <option value=\"Medium\">Medium</option>\n                        <option value=\"High\">High</option>\n                        <option value=\"Critical\">Critical</option>\n                      </select>\n                    </div>\n                  </div>\n                  <div>\n                    <label className=\"block text-[10px] text-slate-500 mb-0.5\">Waste Footprint Description</label>\n                    <input\n                      type=\"text\"\n                      value={manualWaste}\n                      onChange={(e) => setManualWaste(e.target.value)}\n                      placeholder=\"e.g. 500 liters of water leaking daily, hazardous road blocks\"\n                      className=\"w-full bg-slate-50 border border-slate-300 rounded py-1 px-2 text-slate-800 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                    />\n                  </div>\n                </div>\n\n                {/* Form Action Buttons */}\n                <div className=\"flex gap-2 pt-3 border-t border-slate-200 justify-end\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setReportTitle(\"\");\n                      setReportDesc(\"\");\n                      setAiAnalysis(null);\n                      setActiveTab(\"issues\");\n                    }}\n                    className=\"px-3 py-1.5 bg-white border border-slate-300 hover:bg-slate-50 rounded text-xs font-bold text-slate-600 transition-all cursor-pointer\"\n                  >\n                    Cancel\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"flex items-center gap-1.5 bg-slate-900 text-white font-bold px-4 py-1.5 rounded text-xs hover:bg-slate-800 transition-all cursor-pointer shadow-sm\"\n                  >\n                    <Send className=\"h-3.5 w-3.5\" />\n                    Publish Report\n                  </button>\n                </div>\n              </form>\n            </div>\n          )}\n\n          {/* TAB 3: MONTHLY RESIDENT WELL-BEING SURVEY (Resident only) */}\n          {activeTab === \"survey\" && (\n            <div className=\"space-y-4 max-w-xl mx-auto\">\n              <div>\n                <h2 className=\"text-base font-bold tracking-tight text-slate-900\">Monthly Citizen Feedback & Well-being</h2>\n                <p className=\"text-slate-500 text-xs mt-0.5\">Your ratings directly drive accountability metrics, which are publicized for future political voting scorecards.</p>\n              </div>\n\n              {surveySuccess ? (\n                <div className=\"bg-emerald-50 border border-emerald-200 p-5 rounded text-center space-y-3 shadow-sm\">\n                  <CheckCircle2 className=\"h-10 w-10 text-emerald-600 mx-auto animate-bounce\" />\n                  <h3 className=\"font-bold text-sm text-slate-900\">Feedback Submitted Successfully!</h3>\n                  <p className=\"text-slate-600 text-xs max-w-xs mx-auto\">Thank you. Your voice contributes to the public service delivery scorecard of the administration and neighborhood handymen.</p>\n                  <button\n                    onClick={() => setSurveySuccess(false)}\n                    className=\"bg-slate-900 text-white px-3 py-1.5 rounded text-xs font-bold transition-all hover:bg-slate-800 cursor-pointer shadow-sm\"\n                  >\n                    Submit New Survey Update\n                  </button>\n                </div>\n              ) : (\n                <form onSubmit={handleSurveySubmit} className=\"bg-white border border-slate-300 p-5 rounded space-y-4 shadow-sm\">\n                  {surveyError && (\n                    <div className=\"p-2.5 bg-red-50 border border-red-200 rounded text-xs text-red-700 flex items-center gap-1.5 font-medium\">\n                      <AlertCircle className=\"h-3.5 w-3.5\" /> {surveyError}\n                    </div>\n                  )}\n\n                  <div className=\"p-3 bg-slate-50 border border-slate-200 rounded space-y-0.5\">\n                    <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase font-bold\">ACTIVE PERIOD</span>\n                    <p className=\"text-xs text-slate-800 font-semibold flex items-center gap-1\">\n                      <Calendar className=\"h-3.5 w-3.5 text-slate-500\" /> June 2026 Feedback Drive\n                    </p>\n                  </div>\n\n                  {/* Rating 1: Overall Happiness */}\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                      1. Overall Community Well-being & Happiness (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyHappiness(val)}\n                          className={`flex-1 py-1.5 text-xs font-bold rounded border transition-all cursor-pointer ${\n                            surveyHappiness === val\n                              ? \"bg-slate-900 border-slate-700 text-white shadow-sm\"\n                              : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-50\"\n                          }`}\n                        >\n                          {val === 1 ? \"\360\237\230\236\" : val === 3 ? \"\360\237\230\220\" : val === 5 ? \"\360\237\244\251\" : \"\"} {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 2: Local Services */}\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                      2. Public Services & Speed of Repairs (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyServices(val)}\n                          className={`flex-1 py-1.5 text-xs font-bold rounded border transition-all cursor-pointer ${\n                            surveyServices === val\n                              ? \"bg-slate-900 border-slate-700 text-white shadow-sm\"\n                              : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-50\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 3: Road Quality */}\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                      3. Road Infrastructure & Streetlights (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyRoads(val)}\n                          className={`flex-1 py-1.5 text-xs font-bold rounded border transition-all cursor-pointer ${\n                            surveyRoads === val\n                              ? \"bg-slate-900 border-slate-700 text-white shadow-sm\"\n                              : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-50\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Rating 4: Cleanliness */}\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                      4. Cleanliness & Garbage Clearance (1 to 5)\n                    </label>\n                    <div className=\"flex justify-between gap-1\">\n                      {[1, 2, 3, 4, 5].map((val) => (\n                        <button\n                          key={val}\n                          type=\"button\"\n                          onClick={() => setSurveyCleanliness(val)}\n                          className={`flex-1 py-1.5 text-xs font-bold rounded border transition-all cursor-pointer ${\n                            surveyCleanliness === val\n                              ? \"bg-slate-900 border-slate-700 text-white shadow-sm\"\n                              : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-50\"\n                          }`}\n                        >\n                          {val}\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Feedback Text */}\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1\">\n                      Specific Suggestions / Comments\n                    </label>\n                    <textarea\n                      rows={2.5}\n                      value={surveyFeedback}\n                      onChange={(e) => setSurveyFeedback(e.target.value)}\n                      placeholder=\"Share what local authorities or plumbers can do better in your block...\"\n                      className=\"w-full bg-slate-50 border border-slate-300 rounded py-1.5 px-2.5 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    className=\"w-full bg-slate-900 text-white font-bold py-2 rounded hover:bg-slate-800 transition-all text-xs cursor-pointer shadow-sm\"\n                  >\n                    Submit Monthly Evaluation\n                  </button>\n                </form>\n              )}\n            </div>\n          )}\n\n          {/* TAB 4: CONTRACTOR WORKROOM (Contractor only) */}\n          {activeTab === \"contractor\" && (\n            <div className=\"space-y-4\">\n              <div>\n                <h2 className=\"text-base font-bold tracking-tight text-slate-900\">Contractor Workroom</h2>\n                <p className=\"text-slate-500 text-xs mt-0.5 font-sans\">\n                  Welcome back, <strong>{user.name}</strong>. View neighborhood reports that match your trade specialty (\n                  <span className=\"text-emerald-700 font-semibold\">{user.specialty}</span>) to accept jobs, estimate quotes, and claim resolution.\n                </p>\n              </div>\n\n              {/* Grid split: Assigned/Active jobs vs Open Trade Jobs */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                {/* Panel left: Assigned Jobs */}\n                <div className=\"bg-white border border-slate-300 rounded p-4 space-y-3.5 shadow-sm\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider flex items-center gap-1.5 pb-2 border-b border-slate-200\">\n                    <Sliders className=\"h-4 w-4 text-slate-500\" /> My Current Assignments ({\n                      issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length\n                    })\n                  </h3>\n                  \n                  {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").length === 0 ? (\n                    <p className=\"text-xs text-slate-400 py-6 text-center border border-dashed border-slate-200 rounded font-mono\">You have no active assignments. Accept open jobs listed below!</p>\n                  ) : (\n                    <div className=\"space-y-2\">\n                      {issues.filter(i => i.assignedContractorId === user.id && i.status !== \"Resolved\").map(job => (\n                        <div key={job.id} className=\"bg-slate-50 border border-slate-200 rounded p-3 space-y-2.5 text-xs\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"px-1.5 py-0.5 rounded bg-amber-50 border border-amber-200 text-amber-700 font-bold text-[10px]\">\n                              {job.status}\n                            </span>\n                            <span className=\"text-slate-900 font-bold font-mono\">Est: ${job.priceQuote}</span>\n                          </div>\n\n                          <h4 className=\"font-bold text-slate-800 text-xs leading-tight\">{job.title}</h4>\n                          <p className=\"text-slate-500 text-[11px] leading-relaxed line-clamp-2\">{job.description}</p>\n                          <div className=\"text-[10px] bg-white border border-slate-200 p-2 rounded text-slate-600\">\n                            <strong className=\"text-slate-800 block mb-0.5 uppercase tracking-wider text-[9px]\">Resident location:</strong>\n                            House {job.reporterHouse} \342\200\242 {job.reporterName}\n                          </div>\n\n                          <div className=\"flex gap-2 pt-2 border-t border-slate-200\">\n                            {job.status === \"Assigned\" && (\n                              <button\n                                onClick={() => handleStartProgress(job.id)}\n                                className=\"flex-1 bg-slate-900 text-white font-bold py-1.5 rounded text-xs hover:bg-slate-800 transition-all cursor-pointer shadow-sm\"\n                              >\n                                Start Work Progress\n                              </button>\n                            )}\n\n                            {job.status === \"In Progress\" && (\n                              <div className=\"w-full space-y-1.5\">\n                                <input\n                                  type=\"text\"\n                                  placeholder=\"Resolution notes (materials used, steps taken)...\"\n                                  value={resolutionNotesInput}\n                                  onChange={(e) => setResolutionNotesInput(e.target.value)}\n                                  className=\"w-full bg-white border border-slate-300 rounded p-1.5 text-xs text-slate-900 placeholder-slate-400 focus:outline-none focus:border-slate-500 font-sans\"\n                                />\n                                <button\n                                  onClick={() => handleResolveIssue(job.id)}\n                                  className=\"w-full bg-emerald-600 text-white font-bold py-1.5 rounded text-xs hover:bg-emerald-700 transition-all cursor-pointer shadow-sm\"\n                                >\n                                  Submit Resolution & Request Payout\n                                </button>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n\n                  {/* Panel sub section: Received payouts */}\n                  <div className=\"border-t border-slate-200 pt-3 space-y-2\">\n                    <h4 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider flex items-center gap-1\">\n                      <DollarSign className=\"h-4 w-4 text-emerald-600\" /> Earnings & Payout Status\n                    </h4>\n                    <div className=\"bg-slate-50 p-2.5 rounded border border-slate-200 space-y-1.5 text-[11px]\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Completed jobs paid:</span>\n                        <span className=\"text-emerald-700 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-500\">Pending administrative payout release:</span>\n                        <span className=\"text-amber-700 font-bold font-mono\">\n                          ${issues.filter(i => i.assignedContractorId === user.id && i.status === \"Resolved\" && !i.isPaid).reduce((acc, job) => acc + (job.priceQuote || 0), 0)}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Panel right: Open Jobs Matching Trade Specialty */}\n                <div className=\"bg-white border border-slate-300 rounded p-4 space-y-3.5 shadow-sm\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider flex items-center gap-1.5 pb-2 border-b border-slate-200\">\n                    <CheckCircle className=\"h-4 w-4 text-slate-500\" /> Open Service Inquiries (Matching: {user.specialty})\n                  </h3>\n\n                  {issues.filter(\n                    i => !i.assignedContractorId && (\n                      (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                      (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                      (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                      (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                      (i.category === \"Public Infrastructure\")\n                    )\n                  ).length === 0 ? (\n                    <p className=\"text-xs text-slate-400 py-12 text-center border border-dashed border-slate-200 rounded font-mono\">No open service requests are matching your specialty trade at the moment.</p>\n                  ) : (\n                    <div className=\"space-y-2\">\n                      {issues.filter(\n                        i => !i.assignedContractorId && (\n                          (user.specialty === \"Plumber\" && i.category === \"Water Leakage\") ||\n                          (user.specialty === \"Electrician\" && i.category === \"Damaged Streetlight\") ||\n                          (user.specialty === \"Waste Management\" && i.category === \"Waste Management\") ||\n                          (user.specialty === \"Roads\" && i.category === \"Pothole\") ||\n                          (i.category === \"Public Infrastructure\")\n                        )\n                      ).map(openJob => (\n                        <div key={openJob.id} className=\"bg-slate-50 border border-slate-200 rounded p-3 space-y-2 text-xs\">\n                          <div className=\"flex justify-between items-center text-xs\">\n                            <span className=\"font-bold text-emerald-700 font-mono text-[9px] uppercase\">\n                              {openJob.category}\n                            </span>\n                            <span className=\"text-slate-500 font-mono text-[9px]\">\n                              {openJob.upvotes.length} validations\n                            </span>\n                          </div>\n\n                          <h4 className=\"font-bold text-slate-800 text-xs leading-tight\">{openJob.title}</h4>\n                          <p className=\"text-slate-500 text-[11px] leading-relaxed\">{openJob.description}</p>\n                          <div className=\"text-[10px] bg-white border border-slate-200 p-2 rounded text-slate-600 space-y-1\">\n                            <div><strong>Impact details:</strong> {openJob.wasteCaused}</div>\n                            <div><strong>Hours unattended:</strong> {openJob.daysUnattended * 24} hours unaddressed</div>\n                          </div>\n\n                          {selectedIssueForAction === openJob.id ? (\n                            <div className=\"bg-white border border-slate-300 p-2.5 rounded space-y-2 text-xs animate-fadeIn\">\n                              <div>\n                                <label className=\"block text-[9px] text-slate-500 mb-0.5 font-bold uppercase tracking-wider\">My Price Quote ($ USD)</label>\n                                <input\n                                  type=\"number\"\n                                  value={priceQuoteInput}\n                                  onChange={(e) => setPriceQuoteInput(e.target.value)}\n                                  className=\"w-full bg-slate-50 border border-slate-300 rounded p-1.5 text-xs text-slate-900 focus:outline-none focus:border-slate-500 font-mono\"\n                                />\n                              </div>\n                              <div className=\"flex gap-2\">\n                                <button\n                                  onClick={() => setSelectedIssueForAction(null)}\n                                  className=\"flex-1 bg-white hover:bg-slate-50 border border-slate-300 rounded py-1 text-xs text-slate-500 transition-all cursor-pointer\"\n                                >\n                                  Cancel\n                                </button>\n                                <button\n                                  onClick={() => handleAcceptAssignment(openJob.id)}\n                                  className=\"flex-1 bg-slate-900 text-white font-bold py-1 rounded text-xs hover:bg-slate-800 transition-all cursor-pointer shadow-sm\"\n                                >\n                                  Submit Bid & Accept\n                                </button>\n                              </div>\n                            </div>\n                          ) : (\n                            <button\n                              onClick={() => {\n                                setSelectedIssueForAction(openJob.id);\n                                setPriceQuoteInput(\"150\");\n                              }}\n                              className=\"w-full bg-white hover:bg-slate-50 border border-slate-300 text-slate-700 font-bold py-1.5 rounded text-xs transition-all cursor-pointer\"\n                            >\n                              Accept Job Assignment\n                            </button>\n                          )}\n                        </div>\n                      ))}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* TAB 5: GOVERNANCE & ANALYTICS DASHBOARD (Admin/Elected Official only) */}\n          {activeTab === \"admin-dashboard\" && (\n            <div className=\"space-y-4 animate-fadeIn\">\n              <div>\n                <h2 className=\"text-base font-bold tracking-tight text-slate-900\">Elected Official Command Center</h2>\n                <p className=\"text-slate-500 text-xs mt-0.5 font-sans\">Monitor neighborhood status, contractor speed performance indices, and resident happiness surveys for future voting times.</p>\n              </div>\n\n              {/* Stat Bento Grids */}\n              <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3\">\n                <div className=\"bg-white border border-slate-300 rounded p-3 text-left shadow-sm\">\n                  <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase font-bold\">ACTIVE REQUESTS</span>\n                  <p className=\"text-xl font-extrabold text-slate-900 mt-0.5 font-mono\">\n                    {issues.filter(i => i.status !== \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-red-600 font-medium block mt-0.5\">Needs attention</span>\n                </div>\n                <div className=\"bg-white border border-slate-300 rounded p-3 text-left shadow-sm\">\n                  <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase font-bold\">RESOLVED JOBS</span>\n                  <p className=\"text-xl font-extrabold text-emerald-700 mt-0.5 font-mono\">\n                    {issues.filter(i => i.status === \"Resolved\").length}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-medium block mt-0.5 font-mono\">Fixes completed</span>\n                </div>\n                <div className=\"bg-white border border-slate-300 rounded p-3 text-left shadow-sm\">\n                  <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase font-bold\">WELLBEING INDEX</span>\n                  <p className=\"text-xl font-extrabold text-slate-900 mt-0.5 font-mono\">\n                    {adminSurveys.length > 0\n                      ? (adminSurveys.reduce((acc, s) => acc + s.overallHappiness, 0) / adminSurveys.length).toFixed(1)\n                      : \"4.2\"\n                    }/5.0\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-medium block mt-0.5\">Citizen approval</span>\n                </div>\n                <div className=\"bg-white border border-slate-300 rounded p-3 text-left shadow-sm\">\n                  <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase font-bold\">REVENUE RESOLUTION</span>\n                  <p className=\"text-xl font-extrabold text-slate-900 mt-0.5 font-mono\">\n                    ${issues.filter(i => i.status === \"Resolved\").reduce((acc, i) => acc + (i.priceQuote || 0), 0)}\n                  </p>\n                  <span className=\"text-[10px] text-slate-500 font-medium block mt-0.5\">Contractor payouts</span>\n                </div>\n              </div>\n\n              {/* Stat charts with recharts */}\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                {/* Chart 1: Category Distribution */}\n                <div className=\"bg-white border border-slate-300 p-4 rounded shadow-sm space-y-3\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider\">Issues Distribution by Category</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-400 font-mono\">No category data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <PieChart>\n                          <Pie\n                            data={getCategoryChartData()}\n                            cx=\"50%\"\n                            cy=\"50%\"\n                            innerRadius={55}\n                            outerRadius={75}\n                            paddingAngle={4}\n                            dataKey=\"value\"\n                          >\n                            {getCategoryChartData().map((entry, index) => (\n                              <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\n                            ))}\n                          </Pie>\n                          <Tooltip contentStyle={{ backgroundColor: \"#ffffff\", border: \"1px solid #cbd5e1\", fontSize: \"10px\", color: \"#0f172a\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"10px\" }} />\n                        </PieChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 2: Status distribution */}\n                <div className=\"bg-white border border-slate-300 p-4 rounded shadow-sm space-y-3\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider\">Issue Lifespans & Status Overview</h3>\n                  <div className=\"h-64\">\n                    {issues.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-400 font-mono\">No status data yet.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getStatusChartData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" />\n                          <XAxis dataKey=\"name\" stroke=\"#64748b\" fontSize={10} />\n                          <YAxis stroke=\"#64748b\" fontSize={10} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#ffffff\", border: \"1px solid #cbd5e1\", fontSize: \"10px\", color: \"#0f172a\" }} />\n                          <Bar dataKey=\"count\" fill=\"#475569\" radius={[2, 2, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n\n                {/* Chart 3: Resident surveys approval trend */}\n                <div className=\"bg-white border border-slate-300 p-4 rounded shadow-sm space-y-3 lg:col-span-2\">\n                  <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider\">Resident Well-being and Infrastructure Approval Indices</h3>\n                  <div className=\"h-64\">\n                    {adminSurveys.length === 0 ? (\n                      <div className=\"h-full flex items-center justify-center text-xs text-slate-400 font-mono\">Waiting for first monthly surveys to show trends.</div>\n                    ) : (\n                      <ResponsiveContainer width=\"100%\" height=\"100%\">\n                        <BarChart data={getSurveyWellbeingData()}>\n                          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" />\n                          <XAxis dataKey=\"month\" stroke=\"#64748b\" fontSize={10} />\n                          <YAxis stroke=\"#64748b\" fontSize={10} domain={[0, 5]} />\n                          <Tooltip contentStyle={{ backgroundColor: \"#ffffff\", border: \"1px solid #cbd5e1\", fontSize: \"10px\", color: \"#0f172a\" }} />\n                          <Legend wrapperStyle={{ fontSize: \"10px\" }} />\n                          <Bar dataKey=\"Happiness\" fill=\"#0f172a\" radius={[2, 2, 0, 0]} />\n                          <Bar dataKey=\"Service Delivery\" fill=\"#2563eb\" radius={[2, 2, 0, 0]} />\n                          <Bar dataKey=\"Road Safety\" fill=\"#ca8a04\" radius={[2, 2, 0, 0]} />\n                          <Bar dataKey=\"Sanitation\" fill=\"#16a34a\" radius={[2, 2, 0, 0]} />\n                        </BarChart>\n                      </ResponsiveContainer>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              {/* Interactive Contractor Invoices & Payments Section */}\n              <div className=\"bg-white border border-slate-300 p-4 rounded shadow-sm space-y-3\">\n                <h3 className=\"font-bold text-xs text-slate-800 uppercase tracking-wider flex items-center gap-1.5 pb-1\">\n                  <DollarSign className=\"h-4 w-4 text-emerald-600\" /> Pending Contractor Payments & Public Budget Releases\n                </h3>\n\n                {issues.filter(i => i.status === \"Resolved\").length === 0 ? (\n                  <p className=\"text-xs text-slate-400 py-6 text-center border border-dashed border-slate-200 rounded font-mono\">No completed handyman resolutions require payment releases at this hour.</p>\n                ) : (\n                  <div className=\"overflow-x-auto border border-slate-200 rounded\">\n                    <table className=\"w-full text-left border-collapse text-xs\">\n                      <thead>\n                        <tr className=\"border-b border-slate-200 text-slate-500 font-bold bg-slate-50 text-[10px] uppercase tracking-wider\">\n                          <th className=\"p-2.5\">Issue ID</th>\n                          <th className=\"p-2.5\">Title / Resolution</th>\n                          <th className=\"p-2.5\">Assigned Handyman</th>\n                          <th className=\"p-2.5\">Estimated Quote</th>\n                          <th className=\"p-2.5\">Payment Status</th>\n                          <th className=\"p-2.5 text-right\">Action</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-slate-100\">\n                        {issues.filter(i => i.status === \"Resolved\").map(completedIssue => (\n                          <tr key={completedIssue.id} className=\"hover:bg-slate-50/50 transition-all\">\n                            <td className=\"p-2.5 font-mono text-slate-400 text-[11px]\">{completedIssue.id}</td>\n                            <td className=\"p-2.5 max-w-xs\">\n                              <span className=\"font-bold text-slate-800 block\">{completedIssue.title}</span>\n                              <span className=\"text-slate-500 text-[10px] block mt-0.5 italic\">\342\200\234{completedIssue.resolutionNotes}\342\200\235</span>\n                            </td>\n                            <td className=\"p-2.5 text-slate-700 font-semibold\">{completedIssue.assignedContractorName}</td>\n                            <td className=\"p-2.5 font-mono font-bold text-slate-900\">${completedIssue.priceQuote}</td>\n                            <td className=\"p-2.5\">\n                              {completedIssue.isPaid ? (\n                                <span className=\"inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-emerald-50 border border-emerald-200 text-emerald-700 font-bold text-[10px]\">\n                                  Released\n                                </span>\n                              ) : (\n                                <span className=\"inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-50 border border-amber-200 text-amber-700 font-bold text-[10px]\">\n                                  Pending Review\n                                </span>\n                              )}\n                            </td>\n                            <td className=\"p-2.5 text-right\">\n                              {!completedIssue.isPaid && (\n                                <button\n                                  onClick={() => handleReleasePayment(completedIssue.id)}\n                                  className=\"bg-slate-900 hover:bg-slate-800 text-white font-bold py-1 px-2.5 rounded text-[11px] transition-all cursor-pointer shadow-sm\"\n                                >\n                                  Release Payout\n                                </button>\n                              )}\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </div>\n            </div>\n          )}\n\n          {/* TAB 6: ADMIN RESIDENT WELL-BEING INBOX (Admin only) */}\n          {activeTab === \"admin-surveys\" && (\n            <div className=\"space-y-4\">\n              <div>\n                <h2 className=\"text-base font-bold tracking-tight text-slate-900\">Resident Well-being Inbox</h2>\n                <p className=\"text-slate-500 text-xs mt-0.5\">Review feedback surveys left by residents during monthly public satisfaction initiatives.</p>\n              </div>\n\n              {adminSurveys.length === 0 ? (\n                <div className=\"bg-white border border-slate-300 rounded p-10 text-center shadow-sm\">\n                  <MessageSquare className=\"h-8 w-8 text-slate-400 mx-auto mb-2\" />\n                  <h3 className=\"font-bold text-sm text-slate-900\">Inbox is Empty</h3>\n                  <p className=\"text-slate-500 text-xs max-w-xs mx-auto mt-1\">There are no surveys or qualitative reports registered by citizens in the system yet.</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                  {adminSurveys.map((survey) => (\n                    <div key={survey.id} className=\"bg-white border border-slate-300 p-4 rounded flex flex-col justify-between shadow-sm space-y-3.5\">\n                      <div>\n                        {/* Title line */}\n                        <div className=\"flex justify-between items-center pb-2 border-b border-slate-200\">\n                          <div>\n                            <span className=\"text-xs font-bold text-slate-900\">{survey.residentName}</span>\n                            <span className=\"text-[10px] text-slate-400 font-mono block\">Period: {survey.month}</span>\n                          </div>\n                          <span className=\"text-[10px] text-slate-400 font-mono\">{new Date(survey.date).toLocaleDateString()}</span>\n                        </div>\n\n                        {/* Ratings overview */}\n                        <div className=\"grid grid-cols-2 gap-1.5 text-xs pt-2.5\">\n                          <div className=\"bg-slate-50 p-1.5 rounded flex justify-between items-center border border-slate-200\">\n                            <span className=\"text-slate-500 text-[10px]\">Happiness:</span>\n                            <span className=\"font-bold text-slate-950 font-mono\">{survey.overallHappiness}/5</span>\n                          </div>\n                          <div className=\"bg-slate-50 p-1.5 rounded flex justify-between items-center border border-slate-200\">\n                            <span className=\"text-slate-500 text-[10px]\">Services Speed:</span>\n                            <span className=\"font-bold text-slate-950 font-mono\">{survey.localServicesRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-50 p-1.5 rounded flex justify-between items-center border border-slate-200\">\n                            <span className=\"text-slate-500 text-[10px]\">Road Quality:</span>\n                            <span className=\"font-bold text-slate-950 font-mono\">{survey.roadQualityRating}/5</span>\n                          </div>\n                          <div className=\"bg-slate-50 p-1.5 rounded flex justify-between items-center border border-slate-200\">\n                            <span className=\"text-slate-500 text-[10px]\">Cleanliness:</span>\n                            <span className=\"font-bold text-slate-950 font-mono\">{survey.cleanlinessRating}/5</span>\n                          </div>\n                        </div>\n\n                        {/* Qualitative note */}\n                        {survey.feedbackText && (\n                          <div className=\"bg-slate-50 p-2.5 rounded border border-slate-200 mt-2.5 text-xs leading-normal\">\n                            <strong className=\"text-slate-500 block mb-0.5 text-[10px] uppercase tracking-wider\">Suggestions & Observations:</strong>\n                            <p className=\"text-slate-700\">\342\200\234{survey.feedbackText}\342\200\235</p>\n                          </div>\n                        )}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n        </main>\n      </div>\n\n      {/* Footer Info bar */}\n      <footer className=\"bg-slate-900 border-t border-slate-800 py-4 text-center text-[10px] text-slate-400 font-mono uppercase tracking-widest\">\n        <p>Community Hero Hyperlocal Problem Solver \302\251 2026. Empowering Neighborhood Transparency & Public Infrastructure Resolution.</p>\n      </footer>\n    </div>\n  );\n}"
