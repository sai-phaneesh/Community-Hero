      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport fs from \"fs\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI, Type } from \"@google/genai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\n// Initialize Gemini API\nconst geminiApiKey = process.env.GEMINI_API_KEY;\nlet ai: GoogleGenAI | null = null;\n\nif (geminiApiKey && geminiApiKey !== \"MY_GEMINI_API_KEY\") {\n  try {\n    ai = new GoogleGenAI({\n      apiKey: geminiApiKey,\n      httpOptions: {\n        headers: {\n          \"User-Agent\": \"aistudio-build\",\n        },\n      },\n    });\n    console.log(\"Gemini API Client initialized successfully.\");\n  } catch (e) {\n    console.error(\"Failed to initialize Gemini API Client:\", e);\n  }\n} else {\n  console.log(\"No valid GEMINI_API_KEY found. Issues will use automatic local analysis rules.\");\n}\n\nconst app = express();\nconst PORT = 3000;\n\napp.use(express.json());\n\n// --- DATABASE SETUP ---\nconst DB_FILE = path.join(process.cwd(), \"db.json\");\n\ninterface User {\n  id: string;\n  email: string;\n  password?: string;\n  role: \"resident\" | \"contractor\" | \"admin\";\n  name: string;\n  phone: string;\n  houseNumber?: string;\n  specialty?: string; // For contractors\n}\n\ninterface Issue {\n  id: string;\n  title: string;\n  description: string;\n  category: string;\n  severity: \"Low\" | \"Medium\" | \"High\" | \"Critical\";\n  wasteCaused: string;\n  status: \"Reported\" | \"Validated\" | \"Assigned\" | \"In Progress\" | \"Resolved\";\n  reporterId: string;\n  reporterName: string;\n  reporterHouse: string;\n  upvotes: string[]; // List of user IDs\n  createdAt: string;\n  daysUnattended: number;\n  assignedContractorId?: string;\n  assignedContractorName?: string;\n  resolutionNotes?: string;\n  priceQuote?: number;\n  isPaid?: boolean;\n}\n\ninterface Survey {\n  id: string;\n  month: string;\n  residentId: string;\n  residentName: string;\n  overallHappiness: number;\n  localServicesRating: number;\n  roadQualityRating: number;\n  cleanlinessRating: number;\n  feedbackText: string;\n  date: string;\n}\n\ninterface Notification {\n  id: string;\n  userId: string;\n  title: string;\n  message: string;\n  read: boolean;\n  createdAt: string;\n}\n\ninterface DB {\n  users: User[];\n  issues: Issue[];\n  surveys: Survey[];\n  notifications: Notification[];\n}\n\nconst defaultDB: DB = {\n  users: [\n    {\n      id: \"u-admin\",\n      email: \"admin@community.org\",\n      password: \"admin123\",\n      role: \"admin\",\n      name: \"Elected Official (Admin)\",\n      phone: \"+1 555-0100\",\n    },\n    {\n      id: \"u-res-1\",\n      email: \"john@resident.com\",\n      password: \"john123\",\n      role: \"resident\",\n      name: \"John Resident\",\n      phone: \"+1 555-0199\",\n      houseNumber: \"A-12\",\n    },\n    {\n      id: \"u-con-1\",\n      email: \"plumber@service.com\",\n      password: \"plumber123\",\n      role: \"contractor\",\n      name: \"Bob\'s Plumbing Co.\",\n      phone: \"+1 555-0144\",\n      specialty: \"Plumber\",\n    },\n    {\n      id: \"u-con-2\",\n      email: \"electrician@service.com\",\n      password: \"electrician123\",\n      role: \"contractor\",\n      name: \"Sparky Electrical\",\n      phone: \"+1 555-0155\",\n      specialty: \"Electrician\",\n    },\n  ],\n  issues: [\n    {\n      id: \"iss-1\",\n      title: \"Major Main Line Water Leakage\",\n      description: \"Water has been leaking from the pavement near house A-12. It\'s pooling and causing damage to the sidewalk. Constant stream of clean water going to waste.\",\n      category: \"Water Leakage\",\n      severity: \"High\",\n      wasteCaused: \"Estimated 1,200 liters of treated water lost per day.\",\n      status: \"Reported\",\n      reporterId: \"u-res-1\",\n      reporterName: \"John Resident\",\n      reporterHouse: \"A-12\",\n      upvotes: [\"u-res-1\"],\n      createdAt: new Date(Date.now() - 4 * 24 * 60 * 60 * 1000).toISOString(), // 4 days ago\n      daysUnattended: 4,\n    },\n    {\n      id: \"iss-2\",\n      title: \"Broken Streetlight on Lane 4\",\n      description: \"Streetlight outside of Lane 4 has been flickering and is now completely out. Makes the area feel unsafe at night.\",\n      category: \"Damaged Streetlight\",\n      severity: \"Medium\",\n      wasteCaused: \"Increased security hazard. No energy waste but severe public risk.\",\n      status: \"Assigned\",\n      reporterId: \"u-res-1\",\n      reporterName: \"John Resident\",\n      reporterHouse: \"A-12\",\n      upvotes: [],\n      createdAt: new Date(Date.now() - 6 * 24 * 60 * 60 * 1000).toISOString(), // 6 days ago\n      daysUnattended: 6,\n      assignedContractorId: \"u-con-2\",\n      assignedContractorName: \"Sparky Electrical\",\n      priceQuote: 180,\n      isPaid: false,\n    },\n  ],\n  surveys: [\n    {\n      id: \"srv-1\",\n      month: \"June 2026\",\n      residentId: \"u-res-1\",\n      residentName: \"John Resident\",\n      overallHappiness: 4,\n      localServicesRating: 3,\n      roadQualityRating: 2,\n      cleanlinessRating: 4,\n      feedbackText: \"The waste management is good, but pothole repairs and broken streetlights take too long to resolve.\",\n      date: new Date(Date.now() - 5 * 24 * 60 * 60 * 1000).toISOString(),\n    },\n  ],\n  notifications: [\n    {\n      id: \"not-1\",\n      userId: \"u-res-1\",\n      title: \"Issue Status Update\",\n      message: \"Your reported issue \'Broken Streetlight on Lane 4\' has been assigned to Sparky Electrical.\",\n      read: false,\n      createdAt: new Date().toISOString(),\n    },\n  ],\n};\n\nfunction readDB(): DB {\n  try {\n    if (!fs.existsSync(DB_FILE)) {\n      fs.writeFileSync(DB_FILE, JSON.stringify(defaultDB, null, 2));\n      return defaultDB;\n    }\n    const data = fs.readFileSync(DB_FILE, \"utf-8\");\n    return JSON.parse(data);\n  } catch (e) {\n    console.error(\"Error reading database file, returning defaults\", e);\n    return defaultDB;\n  }\n}\n\nfunction writeDB(db: DB) {\n  try {\n    fs.writeFileSync(DB_FILE, JSON.stringify(db, null, 2));\n  } catch (e) {\n    console.error(\"Error writing to database file\", e);\n  }\n}\n\n// Ensure database file is initialized on load\nreadDB();\n\n// Helper to push notification\nfunction addNotification(userId: string, title: string, message: string) {\n  const db = readDB();\n  db.notifications.push({\n    id: `not-${Date.now()}`,\n    userId,\n    title,\n    message,\n    read: false,\n    createdAt: new Date().toISOString(),\n  });\n  writeDB(db);\n}\n\n// --- API ENDPOINTS ---\n\n// AUTH\napp.post(\"/api/auth/register\", (req, res) => {\n  const { email, password, role, name, phone, houseNumber, specialty } = req.body;\n  if (!email || !password || !role || !name || !phone) {\n    return res.status(400).json({ error: \"Missing required fields.\" });\n  }\n\n  const db = readDB();\n  const existing = db.users.find((u) => u.email.toLowerCase() === email.toLowerCase());\n  if (existing) {\n    return res.status(400).json({ error: \"Email is already registered.\" });\n  }\n\n  const newUser: User = {\n    id: `u-${Date.now()}`,\n    email,\n    password, // Plain text for mock / simple demo purposes, keeps things light\n    role,\n    name,\n    phone,\n    houseNumber: role === \"resident\" ? houseNumber : undefined,\n    specialty: role === \"contractor\" ? specialty : undefined,\n  };\n\n  db.users.push(newUser);\n  writeDB(db);\n\n  const { password: _, ...userWithoutPassword } = newUser;\n  res.status(201).json({ user: userWithoutPassword });\n});\n\napp.post(\"/api/auth/login\", (req, res) => {\n  const { email, password } = req.body;\n  if (!email || !password) {\n    return res.status(400).json({ error: \"Missing email or password.\" });\n  }\n\n  const db = readDB();\n  const user = db.users.find(\n    (u) => u.email.toLowerCase() === email.toLowerCase() && u.password === password\n  );\n\n  if (!user) {\n    return res.status(401).json({ error: \"Invalid email or password.\" });\n  }\n\n  const { password: _, ...userWithoutPassword } = user;\n  res.json({ user: userWithoutPassword });\n});\n\n// GET PROFILE INFO\napp.get(\"/api/users\", (req, res) => {\n  const db = readDB();\n  const safeUsers = db.users.map(({ password: _, ...rest }) => rest);\n  res.json(safeUsers);\n});\n\n// GET ISSUES\napp.get(\"/api/issues\", (req, res) => {\n  const db = readDB();\n  // Update daysUnattended calculation dynamically\n  const now = new Date();\n  const updatedIssues = db.issues.map((iss) => {\n    if (iss.status !== \"Resolved\") {\n      const created = new Date(iss.createdAt);\n      const diffTime = Math.abs(now.getTime() - created.getTime());\n      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n      iss.daysUnattended = diffDays || 1;\n    }\n    return iss;\n  });\n  db.issues = updatedIssues;\n  writeDB(db);\n  res.json(updatedIssues);\n});\n\n// AI CATEGORIZATION AND ENHANCEMENT VIA GEMINI API\napp.post(\"/api/issues/analyze\", async (req, res) => {\n  const { title, description } = req.body;\n  if (!title || !description) {\n    return res.status(400).json({ error: \"Missing title or description.\" });\n  }\n\n  // If Gemini is available, query it!\n  if (ai) {\n    try {\n      const prompt = `Analyze this hyperlocal community issue to automatically categorize it and estimate its impacts.\nTitle: \"${title}\"\nDescription: \"${description}\"\n\nPlease return a structured JSON response with exactly the following schema. Avoid markdown tags around the JSON, return ONLY pure JSON.\n{\n  \"category\": \"Water Leakage\" | \"Pothole\" | \"Waste Management\" | \"Damaged Streetlight\" | \"Public Infrastructure\",\n  \"severity\": \"Low\" | \"Medium\" | \"High\" | \"Critical\",\n  \"wasteCaused\": \"Description of physical or resource waste (e.g., liters of clean water leaking, power grid strain, garbage scattering, health risk)\",\n  \"repairSuggestion\": \"Short action suggestion for plumbers, electricians, or council contractors\",\n  \"authenticityClues\": \"Details in the description that help prove or challenge authenticity\"\n}`;\n\n      const response = await ai.models.generateContent({\n        model: \"gemini-3.5-flash\",\n        contents: prompt,\n        config: {\n          responseMimeType: \"application/json\",\n          temperature: 0.2,\n        },\n      });\n\n      const responseText = response.text || \"{}\";\n      const analysis = JSON.parse(responseText.trim());\n      return res.json(analysis);\n    } catch (err) {\n      console.error(\"Gemini analysis error, falling back to rule-based analysis\", err);\n    }\n  }\n\n  // Rule-based fallback if Gemini API is not configured or fails\n  const lowerTitle = title.toLowerCase();\n  const lowerDesc = description.toLowerCase();\n\n  let category = \"Public Infrastructure\";\n  let severity: \"Low\" | \"Medium\" | \"High\" | \"Critical\" = \"Medium\";\n  let wasteCaused = \"Resource damage & public inconvenience.\";\n  let repairSuggestion = \"Standard contractor repair required.\";\n  let authenticityClues = \"Detailed description provides positive authenticity indicator.\";\n\n  if (lowerTitle.includes(\"leak\") || lowerTitle.includes(\"water\") || lowerDesc.includes(\"leak\") || lowerDesc.includes(\"pipe\")) {\n    category = \"Water Leakage\";\n    severity = \"High\";\n    wasteCaused = \"Estimated 300 to 1,500 liters of treated tap water wasted per day depending on pressure.\";\n    repairSuggestion = \"Immediate pipeline shut-off and joint replacement by a plumber.\";\n  } else if (lowerTitle.includes(\"hole\") || lowerTitle.includes(\"pothole\") || lowerDesc.includes(\"road\") || lowerDesc.includes(\"pothole\")) {\n    category = \"Pothole\";\n    severity = \"Medium\";\n    wasteCaused = \"Wear & tear on resident vehicles, high risk of micro-accidents.\";\n    repairSuggestion = \"Cold asphalt filling and tamping by road repair contractors.\";\n  } else if (lowerTitle.includes(\"light\") || lowerTitle.includes(\"lamp\") || lowerDesc.includes(\"dark\") || lowerDesc.includes(\"streetlight\")) {\n    category = \"Damaged Streetlight\";\n    severity = \"Medium\";\n    wasteCaused = \"Pedestrian risk, visual blackout, minor safety/crime hazard increase.\";\n    repairSuggestion = \"Bulb or photocell replacement by an electrician.\";\n  } else if (lowerTitle.includes(\"trash\") || lowerTitle.includes(\"garbage\") || lowerTitle.includes(\"waste\") || lowerDesc.includes(\"waste\") || lowerDesc.includes(\"litter\")) {\n    category = \"Waste Management\";\n    severity = \"High\";\n    wasteCaused = \"Odor emissions, rodent/pest attraction, soil contamination.\";\n    repairSuggestion = \"Bulk waste disposal truck dispatch and cleanup.\";\n  }\n\n  if (lowerDesc.includes(\"urgent\") || lowerDesc.includes(\"dangerous\") || lowerDesc.includes(\"accident\") || lowerDesc.includes(\"critical\")) {\n    severity = \"Critical\";\n  }\n\n  res.json({\n    category,\n    severity,\n    wasteCaused,\n    repairSuggestion,\n    authenticityClues,\n  });\n});\n\n// REPORT ISSUE\napp.post(\"/api/issues/report\", (req, res) => {\n  const { title, description, category, severity, wasteCaused, reporterId, reporterName, reporterHouse } = req.body;\n\n  if (!title || !description || !reporterId) {\n    return res.status(400).json({ error: \"Missing required fields.\" });\n  }\n\n  const db = readDB();\n  const newIssue: Issue = {\n    id: `iss-${Date.now()}`,\n    title,\n    description,\n    category: category || \"Public Infrastructure\",\n    severity: severity || \"Medium\",\n    wasteCaused: wasteCaused || \"TBD during AI audit.\",\n    status: \"Reported\",\n    reporterId,\n    reporterName: reporterName || \"Anonymous Resident\",\n    reporterHouse: reporterHouse || \"N/A\",\n    upvotes: [reporterId], // Reporter automatically upvotes/validates their own report\n    createdAt: new Date().toISOString(),\n    daysUnattended: 0,\n  };\n\n  db.issues.push(newIssue);\n  writeDB(db);\n\n  // Notify Administrators of the new issue\n  const admins = db.users.filter((u) => u.role === \"admin\");\n  admins.forEach((admin) => {\n    addNotification(\n      admin.id,\n      \"New Issue Reported\",\n      `A new issue \'${title}\' was reported by house ${newIssue.reporterHouse}. AI categorized it as ${newIssue.category}.`\n    );\n  });\n\n  res.status(201).json(newIssue);\n});\n\n// UPVOTE / VALIDATE ISSUE (Community Verification)\napp.post(\"/api/issues/:id/validate\", (req, res) => {\n  const { id } = req.params;\n  const { userId } = req.body;\n\n  if (!userId) {\n    return res.status(400).json({ error: \"Missing userId.\" });\n  }\n\n  const db = readDB();\n  const issue = db.issues.find((iss) => iss.id === id);\n  if (!issue) {\n    return res.status(404).json({ error: \"Issue not found.\" });\n  }\n\n  if (issue.upvotes.includes(userId)) {\n    // Remove upvote\n    issue.upvotes = issue.upvotes.filter((uid) => uid !== userId);\n  } else {\n    // Add upvote\n    issue.upvotes.push(userId);\n  }\n\n  // Update status to Validated if it gets at least 3 community upvotes\n  if (issue.status === \"Reported\" && issue.upvotes.length >= 3) {\n    issue.status = \"Validated\";\n\n    // Notify reporter that their issue is community-validated\n    addNotification(\n      issue.reporterId,\n      \"Issue Validated by Community\",\n      `Your reported issue \'${issue.title}\' has received community validations and is marked as \'Validated\'.`\n    );\n  }\n\n  writeDB(db);\n  res.json(issue);\n});\n\n// ASSIGN CONTRACTOR (Admin Action or Contractor Bidding/Acceptance)\napp.post(\"/api/issues/:id/assign\", (req, res) => {\n  const { id } = req.params;\n  const { contractorId, priceQuote } = req.body;\n\n  if (!contractorId) {\n    return res.status(400).json({ error: \"Missing contractorId.\" });\n  }\n\n  const db = readDB();\n  const issue = db.issues.find((iss) => iss.id === id);\n  const contractor = db.users.find((u) => u.id === contractorId);\n\n  if (!issue) {\n    return res.status(404).json({ error: \"Issue not found.\" });\n  }\n  if (!contractor) {\n    return res.status(404).json({ error: \"Contractor not found.\" });\n  }\n\n  issue.status = \"Assigned\";\n  issue.assignedContractorId = contractorId;\n  issue.assignedContractorName = contractor.name;\n  issue.priceQuote = priceQuote || 150; // default estimated contract cost\n  issue.isPaid = false;\n\n  writeDB(db);\n\n  // Notify reporter\n  addNotification(\n    issue.reporterId,\n    \"Contractor Assigned\",\n    `Local contractor \'${contractor.name}\' has been assigned to resolve \'${issue.title}\'. Quote: $${issue.priceQuote}.`\n  );\n\n  // Notify contractor\n  addNotification(\n    contractorId,\n    \"New Job Assignment\",\n    `You have been assigned to repair \'${issue.title}\' at house ${issue.reporterHouse}.`\n  );\n\n  res.json(issue);\n});\n\n// START IN PROGRESS (Contractor Action)\napp.post(\"/api/issues/:id/start\", (req, res) => {\n  const { id } = req.params;\n  const { contractorId } = req.body;\n\n  const db = readDB();\n  const issue = db.issues.find((iss) => iss.id === id);\n\n  if (!issue) {\n    return res.status(404).json({ error: \"Issue not found.\" });\n  }\n\n  if (issue.assignedContractorId !== contractorId) {\n    return res.status(403).json({ error: \"You are not assigned to this issue.\" });\n  }\n\n  issue.status = \"In Progress\";\n  writeDB(db);\n\n  // Notify reporter\n  addNotification(\n    issue.reporterId,\n    \"Work Started on Issue\",\n    `The assigned contractor has started repair work on \'${issue.title}\'.`\n  );\n\n  res.json(issue);\n});\n\n// RESOLVE ISSUE (Contractor Action)\napp.post(\"/api/issues/:id/resolve\", (req, res) => {\n  const { id } = req.params;\n  const { contractorId, resolutionNotes } = req.body;\n\n  const db = readDB();\n  const issue = db.issues.find((iss) => iss.id === id);\n\n  if (!issue) {\n    return res.status(404).json({ error: \"Issue not found.\" });\n  }\n\n  if (issue.assignedContractorId !== contractorId) {\n    return res.status(403).json({ error: \"You are not assigned to this issue.\" });\n  }\n\n  issue.status = \"Resolved\";\n  issue.resolutionNotes = resolutionNotes || \"Resolved successfully.\";\n  writeDB(db);\n\n  // Notify reporter\n  addNotification(\n    issue.reporterId,\n    \"Issue Resolved\",\n    `Your reported issue \'${issue.title}\' has been resolved. Notes: ${issue.resolutionNotes}.`\n  );\n\n  // Notify admin for payout review\n  const admins = db.users.filter((u) => u.role === \"admin\");\n  admins.forEach((admin) => {\n    addNotification(\n      admin.id,\n      \"Job Resolved - Payout Pending\",\n      `Contractor \'${issue.assignedContractorName}\' completed \'${issue.title}\'. Payout of $${issue.priceQuote} is pending.`\n    );\n  });\n\n  res.json(issue);\n});\n\n// PAY CONTRACTOR (Admin Action)\napp.post(\"/api/issues/:id/pay\", (req, res) => {\n  const { id } = req.params;\n\n  const db = readDB();\n  const issue = db.issues.find((iss) => iss.id === id);\n\n  if (!issue) {\n    return res.status(404).json({ error: \"Issue not found.\" });\n  }\n\n  issue.isPaid = true;\n  writeDB(db);\n\n  // Notify contractor\n  if (issue.assignedContractorId) {\n    addNotification(\n      issue.assignedContractorId,\n      \"Payment Released\",\n      `Elected officials have released the payment of $${issue.priceQuote} for resolving \'${issue.title}\'.`\n    );\n  }\n\n  res.json(issue);\n});\n\n// SURVEY SUBMIT\napp.post(\"/api/surveys\", (req, res) => {\n  const { residentId, residentName, overallHappiness, localServicesRating, roadQualityRating, cleanlinessRating, feedbackText } = req.body;\n\n  if (!residentId || !overallHappiness) {\n    return res.status(400).json({ error: \"Missing required fields.\" });\n  }\n\n  const db = readDB();\n  const months = [\"January\", \"February\", \"March\", \"April\", \"May\", \"June\", \"July\", \"August\", \"September\", \"October\", \"November\", \"December\"];\n  const currentMonthStr = `${months[new Date().getMonth()]} ${new Date().getFullYear()}`;\n\n  // Check if they already submitted for this month\n  const duplicate = db.surveys.find(\n    (s) => s.residentId === residentId && s.month === currentMonthStr\n  );\n\n  if (duplicate) {\n    return res.status(400).json({ error: \"You have already completed this month\'s feedback survey.\" });\n  }\n\n  const newSurvey: Survey = {\n    id: `srv-${Date.now()}`,\n    month: currentMonthStr,\n    residentId,\n    residentName: residentName || \"Resident\",\n    overallHappiness: Number(overallHappiness),\n    localServicesRating: Number(localServicesRating || 3),\n    roadQualityRating: Number(roadQualityRating || 3),\n    cleanlinessRating: Number(cleanlinessRating || 3),\n    feedbackText: feedbackText || \"\",\n    date: new Date().toISOString(),\n  };\n\n  db.surveys.push(newSurvey);\n  writeDB(db);\n\n  // Admin notification\n  const admins = db.users.filter((u) => u.role === \"admin\");\n  admins.forEach((admin) => {\n    addNotification(\n      admin.id,\n      \"New Survey Feedback Received\",\n      `A new monthly survey feedback was submitted by resident \'${newSurvey.residentName}\'.`\n    );\n  });\n\n  res.status(201).json(newSurvey);\n});\n\n// GET SURVEYS (Admin only)\napp.get(\"/api/surveys\", (req, res) => {\n  const db = readDB();\n  res.json(db.surveys);\n});\n\n// GET NOTIFICATIONS\napp.get(\"/api/notifications/:userId\", (req, res) => {\n  const { userId } = req.params;\n  const db = readDB();\n  const userNotifications = db.notifications.filter((n) => n.userId === userId);\n  res.json(userNotifications);\n});\n\n// MARK NOTIFICATION AS READ\napp.post(\"/api/notifications/:id/read\", (req, res) => {\n  const { id } = req.params;\n  const db = readDB();\n  const notif = db.notifications.find((n) => n.id === id);\n  if (notif) {\n    notif.read = true;\n    writeDB(db);\n  }\n  res.json({ success: true });\n});\n\n// --- VITE MIDDLEWARE SETUP ---\nasync function startServer() {\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \"dist\");\n    app.use(express.static(distPath));\n    app.get(\"*\", (req, res) => {\n      res.sendFile(path.join(distPath, \"index.html\"));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`Server running on http://localhost:${PORT}`);\n  });\n}\n\nstartServer();\n"
    }
