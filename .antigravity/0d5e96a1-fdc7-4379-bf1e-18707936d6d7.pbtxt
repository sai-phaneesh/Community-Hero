/>\n                </div>\n                <div className=\"flex gap-2 w-full md:w-auto\">\n                  <div className=\"flex-1 md:flex-none\">\n                    <select\n                      value={filterCategory}\n                      onChange={(e) => setFilterCategory(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl px-3 py-2.5 text-slate-300 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    >\n                      <option value=\"All\">All Categories</option>\n                      <option value=\"Water Leakage\">Water Leakage</option>\n                      <option value=\"Pothole\">Pothole</option>\n                      <option value=\"Waste Management\">Waste Management</option>\n                      <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                      <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                    </select>\n                  </div>\n                  <div className=\"flex-1 md:flex-none\">\n                    <select\n                      value={filterStatus}\n                      onChange={(e) => setFilterStatus(e.target.value)}\n                      className=\"w-full bg-slate-950 border border-slate-800 rounded-xl px-3 py-2.5 text-slate-300 text-sm focus:outline-none focus:ring-1 focus:ring-teal-500\"\n                    >\n                      <option value=\"All\">All Statuses</option>\n                      <option value=\"Reported\">Reported</option>\n                      <option value=\"Validated\">Validated</option>\n                      <option value=\"Assigned\">Assigned</option>\n                      <option value=\"In Progress\">In Progress</option>\n                      <option value=\"Resolved\">Resolved</option>\n                    </select>\n                  </div>\n                </div>\n              </div>\n\n              {/* Grid representation */}\n              {filteredIssues.length === 0 ? (\n                <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-12 text-center\">\n                  <AlertTriangle className=\"h-10 w-10 text-slate-600 mx-auto mb-3\" />\n                  <h3 className=\"font-bold text-lg text-white\">No Issues Found</h3>\n                  <p className=\"text-slate-400 text-sm max-w-sm mx-auto mt-1\">There are no reports matching your search or filter configuration. Check back later!</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                  {filteredIssues.map((issue) => {\n                    const statusColors = {\n                      Reported: \"bg-amber-500/10 border-amber-500/30 text-amber-400\",\n                      Validated: \"bg-blue-500/10 border-blue-500/30 text-blue-400\",\n                      Assigned: \"bg-purple-500/10 border-purple-500/30 text-purple-400\",\n                      \"In Progress\": \"bg-sky-500/10 border-sky-500/30 text-sky-400\",\n                      Resolved: \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\",\n                    };\n\n                    const isUpvoted = issue.upvotes.includes(user.id);\n\n                    return (\n                      <div\n                        key={issue.id}\n                        className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 hover:border-slate-700/80 transition-all flex flex-col justify-between\"\n                      >\n                        <div>\n                          {/* Top tags */}\n                          <div className=\"flex justify-between items-start gap-2 mb-3\">\n                            <span className=\"text-[10px] font-mono tracking-widest text-slate-500 uppercase\">\n                              ID: {issue.id}\n                            </span>\n                            <span className={`px-2 py-0.5 rounded-full text-xs font-semibold border ${statusColors[issue.status]}`}>\n                              {issue.status}\n                            </span>\n                          </div>\n\n                          {/* Title */}\n                          <h3 className=\"font-bold text-lg text-white group-hover:text-teal-400 leading-snug\">\n                            {issue.title}\n                          </h3>\n\n                          {/* Sub info */}\n                          <div className=\"flex items-center gap-2 mt-1.5 text-xs text-slate-400\">\n                            <MapPin className=\"h-3 w-3 shrink-0\" />\n                            <span>House {issue.reporterHouse}</span>\n                            <span>\342\200\242</span>\n                            <span>Reporter: {issue.reporterName}</span>\n                          </div>\n\n                          {/* Description */}\n                          <p className=\"text-slate-300 text-sm mt-3 leading-relaxed\">\n                            {issue.description}\n                          </p>\n\n                          {/* Impact Metrics box */}\n                          <div className=\"mt-4 bg-slate-950/80 border border-slate-800 rounded-xl p-3 space-y-2\">\n                            <div className=\"flex justify-between items-center text-xs\">\n                              <span className=\"text-slate-500 flex items-center gap-1\">\n                                <AlertTriangle className=\"h-3.5 w-3.5 text-rose-400 shrink-0\" />\n                                Category / Severity:\n                              </span>\n                              <span className=\"font-semibold text-slate-300\">\n                                {issue.category} \342\200\242{\" \"}\n                                <span className={\n                                  issue.severity === \"Critical\" || issue.severity === \"High\"\n                                    ? \"text-rose-400 font-bold\"\n                                    : \"text-slate-300\"\n                                }>\n                                  {issue.severity}\n                                </span>\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4 text-xs\">\n                              <span className=\"text-slate-500 shrink-0 flex items-center gap-1\">\n                                <Clock className=\"h-3.5 w-3.5 text-teal-400 shrink-0\" />\n                                Days Unattended:\n                              </span>\n                              <span className=\"font-mono text-slate-300 text-right\">\n                                {issue.status === \"Resolved\" ? \"Resolved\" : `${issue.daysUnattended} days unaddressed`}\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4 text-xs pt-1 border-t border-slate-800/40\">\n                              <span className=\"text-slate-500 shrink-0\">Wasted Resources:</span>\n                              <span className=\"font-semibold text-teal-400 text-right text-[11px]\">\n                                {issue.wasteCaused}\n                              </span>\n                            </div>\n\n                            {issue.assignedContractorName && (\n                              <div className=\"flex justify-between items-center text-xs pt-1 border-t border-slate-800/40\">\n                                <span className=\"text-slate-500 flex items-center gap-1\">\n                                  <UserCheck className=\"h-3.5 w-3.5 text-teal-400 shrink-0\" />\n                                  Assigned Service:\n                                </span>\n                                <span className=\"font-semibold text-teal-300\">\n                                  {issue.assignedContractorName} {issue.priceQuote ? `($${issue.priceQuote})` : \"\"}\n                                </span>\n                              </div>\n                            )}\n\n                            {issue.resolutionNotes && (\n                              <div className=\"bg-emerald-950/20 border border-emerald-500/20 rounded-lg p-2 mt-2 text-xs\">\n                                <span className=\"font-bold text-emerald-400\">Resolution Notes:</span>\n                                <p className=\"text-slate-300 mt-0.5\">{issue.resolutionNotes}</p>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n\n                        {/* Actions line */}\n                        <div className=\"mt-5 pt-4 border-t border-slate-800/60 flex items-center justify-between\">\n                          <button\n                            onClick={() => handleVote(issue.id)}\n                            className={`flex items-center gap-2 px-3.5 py-1.5 rounded-lg text-xs font-semibold border transition-all ${\n                              isUpvoted\n                                ? \"bg-teal-500 border-teal-500 text-slate-950\"\n                                : \"bg-slate-950 border-slate-800 text-slate-400 hover:text-white hover:border-slate-700\"\n                            }`}\n                          >\n                            <ThumbsUp className=\"h-3.5 w-3.5\" />\n                            <span>\n                              {isUpvoted ? \"Validated\" : \"Validate / Upvote\"} ({issue.upvotes.length})\n                            </span>\n                          </button>\n\n                          <div className=\"text-[11px] text-slate-500 font-mono\">\n                            {new Date(issue.createdAt).toLocaleDateString()}\n                          </div>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n              )}\n            </div>\n          )}"
      replacement_content: "        {/* Content Panel Area */}\n        <main className=\"flex-1 min-w-0\">\n          {/* TAB 1: ISSUES HUB */}\n          {activeTab === \"issues\" && (\n            <div className=\"space-y-4\">\n              {/* Header section with search */}\n              <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center\">\n                <div>\n                  <h2 className=\"text-base font-bold tracking-tight text-slate-900 font-sans\">Active Hyperlocal Reports</h2>\n                  <p className=\"text-slate-500 text-xs mt-0.5\">Review, validate, and follow resolving progress of neighborhood requests.</p>\n                </div>\n                {user.role === \"resident\" && (\n                  <button\n                    onClick={() => setActiveTab(\"report\")}\n                    className=\"flex items-center gap-1.5 bg-slate-900 text-white hover:bg-slate-800 font-semibold px-3 py-1.5 rounded text-xs transition-all cursor-pointer shadow-sm\"\n                  >\n                    <PlusCircle className=\"h-3.5 w-3.5\" />\n                    Report Issue\n                  </button>\n                )}\n              </div>\n\n              {/* Filtering Interface */}\n              <div className=\"bg-white border border-slate-300 p-3 rounded flex flex-col sm:flex-row gap-3 items-center shadow-sm\">\n                <div className=\"relative w-full sm:flex-1\">\n                  <Search className=\"absolute left-2.5 top-2.5 h-3.5 w-3.5 text-slate-400\" />\n                  <input\n                    type=\"text\"\n                    value={searchQuery}\n                    onChange={(e) => setSearchQuery(e.target.value)}\n                    placeholder=\"Search issues, descriptions, houses...\"\n                    className=\"w-full bg-slate-50 border border-slate-300 rounded pl-8 pr-3 py-1.5 text-slate-900 placeholder-slate-400 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                  />\n                </div>\n                <div className=\"flex gap-2 w-full sm:w-auto\">\n                  <div className=\"flex-1 sm:flex-none\">\n                    <select\n                      value={filterCategory}\n                      onChange={(e) => setFilterCategory(e.target.value)}\n                      className=\"w-full bg-slate-50 border border-slate-300 rounded px-2.5 py-1.5 text-slate-800 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                    >\n                      <option value=\"All\">All Categories</option>\n                      <option value=\"Water Leakage\">Water Leakage</option>\n                      <option value=\"Pothole\">Pothole</option>\n                      <option value=\"Waste Management\">Waste Management</option>\n                      <option value=\"Damaged Streetlight\">Damaged Streetlight</option>\n                      <option value=\"Public Infrastructure\">Public Infrastructure</option>\n                    </select>\n                  </div>\n                  <div className=\"flex-1 sm:flex-none\">\n                    <select\n                      value={filterStatus}\n                      onChange={(e) => setFilterStatus(e.target.value)}\n                      className=\"w-full bg-slate-50 border border-slate-300 rounded px-2.5 py-1.5 text-slate-800 text-xs focus:outline-none focus:border-slate-500 font-sans\"\n                    >\n                      <option value=\"All\">All Statuses</option>\n                      <option value=\"Reported\">Reported</option>\n                      <option value=\"Validated\">Validated</option>\n                      <option value=\"Assigned\">Assigned</option>\n                      <option value=\"In Progress\">In Progress</option>\n                      <option value=\"Resolved\">Resolved</option>\n                    </select>\n                  </div>\n                </div>\n              </div>\n\n              {/* Grid representation */}\n              {filteredIssues.length === 0 ? (\n                <div className=\"bg-white border border-slate-300 rounded p-10 text-center shadow-sm\">\n                  <AlertTriangle className=\"h-8 w-8 text-slate-400 mx-auto mb-2\" />\n                  <h3 className=\"font-bold text-sm text-slate-900\">No Issues Found</h3>\n                  <p className=\"text-slate-500 text-xs max-w-xs mx-auto mt-1\">There are no reports matching your search or filter configuration. Check back later!</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-3\">\n                  {filteredIssues.map((issue) => {\n                    const statusColors = {\n                      Reported: \"bg-amber-50 border-amber-300 text-amber-700 text-[10px]\",\n                      Validated: \"bg-blue-50 border-blue-300 text-blue-700 text-[10px]\",\n                      Assigned: \"bg-purple-50 border-purple-300 text-purple-700 text-[10px]\",\n                      \"In Progress\": \"bg-sky-50 border-sky-300 text-sky-700 text-[10px]\",\n                      Resolved: \"bg-emerald-50 border-emerald-300 text-emerald-700 text-[10px]\",\n                    };\n\n                    const isUpvoted = issue.upvotes.includes(user.id);\n\n                    return (\n                      <div\n                        key={issue.id}\n                        className=\"bg-white border border-slate-300 rounded p-4 hover:border-slate-400 hover:bg-slate-50/40 transition-all flex flex-col justify-between shadow-sm\"\n                      >\n                        <div>\n                          {/* Top tags */}\n                          <div className=\"flex justify-between items-start gap-2 mb-2\">\n                            <span className=\"text-[9px] font-mono tracking-wider text-slate-400 uppercase\">\n                              ID: {issue.id}\n                            </span>\n                            <span className={`px-1.5 py-0.5 rounded font-bold border ${statusColors[issue.status]}`}>\n                              {issue.status}\n                            </span>\n                          </div>\n\n                          {/* Title */}\n                          <h3 className=\"font-bold text-sm text-slate-900 leading-snug\">\n                            {issue.title}\n                          </h3>\n\n                          {/* Sub info */}\n                          <div className=\"flex items-center gap-2 mt-1 text-[10px] text-slate-500 font-medium\">\n                            <MapPin className=\"h-3 w-3 shrink-0 text-slate-400\" />\n                            <span>House {issue.reporterHouse}</span>\n                            <span>\342\200\242</span>\n                            <span>Reporter: {issue.reporterName}</span>\n                          </div>\n\n                          {/* Description */}\n                          <p className=\"text-slate-600 text-xs mt-2 leading-relaxed\">\n                            {issue.description}\n                          </p>\n\n                          {/* Impact Metrics box */}\n                          <div className=\"mt-3 bg-slate-50 border border-slate-200 rounded p-2.5 space-y-1.5 text-xs\">\n                            <div className=\"flex justify-between items-center\">\n                              <span className=\"text-slate-500 flex items-center gap-1 text-[11px]\">\n                                <AlertTriangle className=\"h-3 w-3 text-red-500 shrink-0\" />\n                                Category / Severity:\n                              </span>\n                              <span className=\"font-semibold text-slate-800 text-[11px]\">\n                                {issue.category} \342\200\242{\" \"}\n                                <span className={\n                                  issue.severity === \"Critical\" || issue.severity === \"High\"\n                                    ? \"text-red-600 font-bold\"\n                                    : \"text-slate-700\"\n                                }>\n                                  {issue.severity}\n                                </span>\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4\">\n                              <span className=\"text-slate-500 shrink-0 flex items-center gap-1 text-[11px]\">\n                                <Clock className=\"h-3 w-3 text-slate-400 shrink-0\" />\n                                Days Unattended:\n                              </span>\n                              <span className=\"font-mono text-slate-700 text-right text-[11px]\">\n                                {issue.status === \"Resolved\" ? \"Resolved\" : `${issue.daysUnattended} days unaddressed`}\n                              </span>\n                            </div>\n                            <div className=\"flex justify-between items-start gap-4 pt-1 border-t border-slate-200\">\n                              <span className=\"text-slate-500 shrink-0 text-[11px]\">Wasted Resources:</span>\n                              <span className=\"font-bold text-emerald-600 text-right text-[11px] font-mono\">\n                                {issue.wasteCaused}\n                              </span>\n                            </div>\n\n                            {issue.assignedContractorName && (\n                              <div className=\"flex justify-between items-center pt-1 border-t border-slate-200\">\n                                <span className=\"text-slate-500 flex items-center gap-1 text-[11px]\">\n                                  <UserCheck className=\"h-3 w-3 text-emerald-600 shrink-0\" />\n                                  Assigned Service:\n                                </span>\n                                <span className=\"font-semibold text-emerald-700 text-[11px]\">\n                                  {issue.assignedContractorName} {issue.priceQuote ? `($${issue.priceQuote})` : \"\"}\n                                </span>\n                              </div>\n                            )}\n\n                            {issue.resolutionNotes && (\n                              <div className=\"bg-emerald-50 border border-emerald-200 rounded p-2 mt-2 text-[10px]\">\n                                <span className=\"font-bold text-emerald-700\">Resolution Notes:</span>\n                                <p className=\"text-slate-600 mt-0.5\">{issue.resolutionNotes}</p>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n\n                        {/* Actions line */}\n                        <div className=\"mt-4 pt-3 border-t border-slate-200 flex items-center justify-between\">\n                          <button\n                            onClick={() => handleVote(issue.id)}\n                            className={`flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-bold border transition-all cursor-pointer ${\n                              isUpvoted\n                                ? \"bg-emerald-600 border-emerald-700 text-white shadow-sm\"\n                                : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-100\"\n                            }`}\n                          >\n                            <ThumbsUp className=\"h-3 w-3\" />\n                            <span>\n                              {isUpvoted ? \"Validated\" : \"Validate\"} ({issue.upvotes.length})\n                            </span>\n                          </button>\n\n                          <div className=\"text-[10px] text-slate-400 font-mono\">\n                            {new Date(issue.createdAt).toLocaleDateString()}\n                          </div>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n              )}\n            </div>\n          )}"
    }
