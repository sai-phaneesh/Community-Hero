an className=\"font-semibold text-emerald-700 text-[11px]\">\n                                  {issue.assignedContractorName} {issue.priceQuote ? `($${issue.priceQuote})` : \"\"}\n                                </span>\n                              </div>\n                            )}\n\n                            {issue.resolutionNotes && (\n                              <div className=\"bg-emerald-50 border border-emerald-200 rounded p-2 mt-2 text-[10px]\">\n                                <span className=\"font-bold text-emerald-700\">Resolution Notes:</span>\n                                <p className=\"text-slate-600 mt-0.5\">{issue.resolutionNotes}</p>\n                              </div>\n                            )}\n                          </div>\n                        </div>\n\n                        {/* Actions line */}\n                        <div className=\"mt-4 pt-3 border-t border-slate-200 flex items-center justify-between\">\n                          <button\n                            onClick={() => handleVote(issue.id)}\n                            className={`flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-bold border transition-all cursor-pointer ${\n                              isUpvoted\n                                ? \"bg-emerald-600 border-emerald-700 text-white shadow-sm\"\n                                : \"bg-white border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-100\"\n                            }`}\n                          >\n                            <ThumbsUp className=\"h-3 w-3\" />\n                            <span>\n                              {isUpvoted ? \"Validated\" : \"Validate\"} ({issue.upvotes.length})\n                            </span>\n                          </button>\n\n                          <div className=\"text-[10px] text-slate-400 font-mono\">\n                            {new Date(issue.createdAt).toLocaleDateString()}\n                       