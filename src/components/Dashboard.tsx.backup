                      className="text-[10px] font-mono text-slate-500 hover:text-emerald-600"
                    >
                      Close
                    </button>
                  </div>
                </div>
                {notifications.length === 0 ? (
                  <p className="text-xs text-slate-400 text-center py-4 font-mono">
