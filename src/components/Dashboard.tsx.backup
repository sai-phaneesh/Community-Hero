          >
            <Award className="h-3.5 w-3.5" />
            Civic Leaderboard
          </button>

          <button
            onClick={() => setActiveTab("profile")}
            className={`flex items-center gap-2.5 px-3 py-2 text-xs font-semibold rounded transition-all ${
